local icon_candidates = {}

local init_timestamp = os.time()
local init_folder = os.date("%Y-%m-%d_%H-%M-%S", init_timestamp)

function file(name, mode, folder)
    local filename = string.format("%s//%s", folder, name)
    local f = io.open(filename, mode)
    if not f then
        printf("Failed to create file %s", filename)
        return nil
    end
    return f
end
function file_for_write(name, folder)
    return file(name, "w+", folder or init_folder)
end
function file_for_read(name, folder)
    return file(name, "r", folder or init_folder)
end

function debug_cmd_list.cmd.export_all(_, txt, x)
    local skip = {
        ["export_translations"] = true,
        ["change_headers_mode"] = true,
        ["export_all"] = true,
        ["export_item_list"] = true,
        ["export_item_icons"] = true,
        ["export_traders_mapping"] = true,
        ["export_outfits"] = true,
        ["export_weapons"] = true,
    }

    for i, cmd in ipairs(cmd_list) do
        if not skip[cmd.cmd] then
            debug_cmd_list.cmd[cmd.cmd](nil, nil, x)
        end
    end

    debug_cmd_list.cmd.export_weapons(nil, nil, x)
    debug_cmd_list.cmd.export_outfits(nil, nil, x)
end

