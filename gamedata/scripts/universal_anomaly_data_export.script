local headers_mode = 1 -- Required for items DB
function debug_cmd_list.cmd.change_headers_mode(_, txt, x)
    headers_mode = (headers_mode + 1) % 2
    local mode_text = headers_mode == 0 and "Translated" or "Translation Keys"
    send_log(x, "Headers mode changed to %s", mode_text)
end


