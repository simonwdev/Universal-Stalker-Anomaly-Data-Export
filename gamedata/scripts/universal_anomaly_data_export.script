function get_perk_artifacts_list()
    local perk_artefacts = {}

    for i, v in pairs(perk_based_artefacts) do
        if type(v) == "table" and string.find(i, "artefact_on_") then
            for j, k in pairs(v) do
                perk_artefacts[j] = "st_pba_" .. j .. "_perk"
            end
        end
    end

    return perk_artefacts
end

function sanitize_perk_description(s)
    -- Strip STALKER color markup non-greedily so multi-segment perk text survives.
    s = s:gsub("%%c%[[^%]]*%]", "")
    -- Collapse runs of whitespace (perk XML has heavy indentation) and trim.
    s = s:gsub("[ \t]+", " "):gsub("^%s+", ""):gsub("%s+$", "")
    return s
end

function get_perk_description(section, perk_key)
    if not perk_key then
        return ""
    end
    -- game.translate_string returns the input unchanged when the key is missing,
    -- so use it to detect whether the perk has localized text at all (e.g. af_lucifer
    -- is registered as a perk artefact but has no st_pba_*_perk string).
    local resolved = game.translate_string(perk_key)
    if not resolved or resolved == "" or resolved == perk_key then
        return ""
    end
    -- Register the key via the standard helper so it lands in translation_keys.csv
    -- and en_us.csv, then emit a value consistent with the current export mode:
    -- in headers_mode=1 the helper returns the key (the downstream pipeline joins
    -- it against translations.json); in headers_mode=0 it returns the actual text.
    local via_helper = translate_with_context(perk_key, "perk for " .. section) or ""
    if via_helper == perk_key then
        return perk_key
    end
    return sanitize_perk_description(via_helper)
end

