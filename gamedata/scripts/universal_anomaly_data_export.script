function debug_cmd_list.cmd.export_traders(_, txt, x)
    send_log(x, "[START] export traders")

    local kind_t = {
        i_arty_junk = true, i_arty = true, i_food = true, i_drink = true, i_misc = true,
        i_medical = true, i_kit = true, i_repair = true, i_upgrade = true,
        o_helmet = true, i_attach = true, i_backpack = true, i_mutant_belt = true,
        i_mutant_part = true, i_mutant_cooked = true, i_mutant_raw = true,
        o_light = true, o_medium = true, o_sci = true, o_heavy = true,
        w_ammo = true, w_melee = true, w_pistol = true, w_shotgun = true,
        w_smg = true, w_rifle = true, w_sniper = true, w_explosive = true,
    }

    local items = {}
    local ltx = ini_file("plugins\\spawner_blacklist.ltx")
    ini_sys:section_for_each(function(sec)
        if
            (not ltx:line_exist("ignore_sections", sec))
            and (not string.find(sec, "tch_"))
            and (not string.find(sec, "mp_"))
            and (not string.find(sec, "_base"))
            and (not string.find(sec, "pn23"))
            and (ini_sys:r_string_ex(sec, "inv_name_short") and ini_sys:r_string_ex(sec, "inv_name"))
            and (not is_weapon_modification(sec))
        then
            local kind = ini_sys:r_string_ex(sec, "kind")
            if kind and kind_t[kind] then
                items[sec] = true
            end
        end
    end)

    local function write_sell_condition_file(ini, base, condlist_str, trader_config)
        local seen = {}
        local ordered = {}
        for _, entry in ipairs(parse_condlist(condlist_str)) do
            if not seen[entry.section] then
                seen[entry.section] = true
                ordered[#ordered + 1] = entry.section
            end
        end

        local discounts = {}
        local no_value_items = {}
        for _, cond_section in ipairs(ordered) do
            local n = ini:line_count(cond_section) or 0
            for i = 0, n - 1 do
                local _, item_id, mult_str = ini:r_line(cond_section, i, "", "")
                if item_id and item_id ~= "" and (not mult_str or mult_str == "") then
                    no_value_items[item_id] = true
                elseif item_id then
                    local str = ini:r_string_ex(cond_section, item_id) or ""
                    local split = str_explode(str, ",")
                    discounts[item_id] = split[1]
                end
            end
        end

        local tbl = {}
        for section, _  in pairs(items) do
            if not no_value_items[section] then
                tbl[section] = discounts[section] or 1
            end
        end

        local f = file_for_write(base .. "sell_condition.csv")
        if not f then return end
        write_csv_header(f, translate_headers({ "~", "st_data_export_price_multiplier" }))
        local sorted = sort_keys(tbl)
        for _, section in ipairs(sorted) do
            write_csv(f, section, tbl[section])
        end
        f:close()
    end

    local function write_buy_condition_file(ini, base, condlist_str, trader_config)
        local seen = {}
        local ordered = {}
        for _, entry in ipairs(parse_condlist(condlist_str)) do
            if not seen[entry.section] then
                seen[entry.section] = true
                ordered[#ordered + 1] = entry.section
            end
        end

        local discounts = {}
        local no_value_items = {}
        for _, cond_section in ipairs(ordered) do
            local n = ini:line_count(cond_section) or 0
            for i = 0, n - 1 do
                local _, item_id, mult_str = ini:r_line(cond_section, i, "", "")
                if item_id and item_id ~= "" and (not mult_str or mult_str == "") then
                    no_value_items[item_id] = true
                elseif item_id then
                    local str = ini:r_string_ex(cond_section, item_id) or ""
                    local split = str_explode(str, ",")
                    discounts[item_id] = split[1]
                end
            end
        end

        local tbl = {}
        for section, _  in pairs(items) do
            if not no_value_items[section] then
                tbl[section] = discounts[section] or 1
            end
        end

        local f = file_for_write(base .. "buy_condition.csv")
        if not f then return end
        write_csv_header(f, translate_headers({ "~", "st_data_export_price_multiplier" }))
        local sorted = sort_keys(tbl)
        for _, section in ipairs(sorted) do
            write_csv(f, section, tbl[section])
        end
        f:close()
    end

    local function write_buy_supplies(base, buy_sup_str)
        local groups  = {}
        local ordered = {}
        for _, entry in ipairs(parse_condlist(buy_sup_str)) do
            if not groups[entry.section] then
                groups[entry.section] = {}
                ordered[#ordered + 1] = entry.section
            end
            if entry.condition then
                groups[entry.section][#groups[entry.section] + 1] = entry.condition
            end
        end

        local f = file_for_write(base .. "buy_supplies.csv")
        if not f then return end
        write_csv_header(f, translate_headers({ "~", "st_data_export_condition" }))
        for _, sup_section in ipairs(ordered) do
            write_csv(f, sup_section, format_condition_list(groups[sup_section]))
        end
        f:close()
    end

    local function write_supply_sections(ini, base, buy_sup_str)
        local seen    = {}
        local ordered = {}
        for _, entry in ipairs(parse_condlist(buy_sup_str)) do
            if not seen[entry.section] then
                seen[entry.section] = true
                ordered[#ordered + 1] = entry.section
            end
        end

        for _, sup_section in ipairs(ordered) do
            local f = file_for_write(base .. sup_section .. ".csv")
            if not f then
                -- continue
            else
                write_csv_header(f, translate_headers({
                    "~", "st_data_export_quantity", "st_data_export_probability"
                }))
                local n = ini:line_count(sup_section) or 0
                for i = 0, n - 1 do
                    local _, item_id, value = ini:r_line(sup_section, i, "", "")
                    translate_with_context(ini_sys:r_string_ex(item_id, "inv_name"), "item name for " .. item_id)
                    if item_id and item_id ~= "" then
                        local parts = str_explode(value or "", ",")
                        write_csv(f, item_id,
                            parts[1] and parts[1]:trim() or "",
                            parts[2] and parts[2]:trim() or "")
                    end
                end
                f:close()
            end
        end
    end

    local function write_discounts(ini, base, discounts_sec)
        local f = file_for_write(base .. "discounts.csv")
        if not f then return end
        write_csv_header(f, translate_headers({
            "st_data_export_discount_type", "st_data_export_discount_value"
        }))
        if discounts_sec and discounts_sec ~= "" then
            local n = ini:line_count(discounts_sec) or 0
            for i = 0, n - 1 do
                local _, dtype, dvalue = ini:r_line(discounts_sec, i, "", "")
                if dtype and dtype ~= "" then
                    write_csv(f, dtype, dvalue or "")
                end
            end
        end
        f:close()
    end

    local function write_trader_data(base, trader_data)
        if not trader_data then return end
        local f = file_for_write(base .. "data.csv")
        if not f then return end
        write_csv_header(f, translate_headers({ "st_data_export_property", "st_data_export_value" }))
        for prop, value in pairs(trader_data) do
            local handler = data_property_handlers[prop]
            local processed = handler and handler(value) or tostring(value)
            write_csv(f, prop, processed)
        end
        f:close()
    end

    --os.execute('mkdir "traders" 2>nul')
    local total = 0

    for _, trader in ipairs(traders) do
        local ini = ini_file(trader.config)
        if not ini then
            send_log(x, "export traders - SKIPPED %s (file not found)", trader.section)
        else
            local base = "traders\\" .. trader.section .. "\\"

            local buy_cond_str  = ini:r_string_ex("trader", "buy_condition")  or ""
            local sell_cond_str = ini:r_string_ex("trader", "sell_condition") or ""
            local buy_sup_str   = ini:r_string_ex("trader", "buy_supplies")   or ""
            local discounts_sec = ini:r_string_ex("trader", "discounts")      or ""

            write_buy_condition_file(ini, base, buy_cond_str, trader.config)
            write_sell_condition_file(ini, base, sell_cond_str, trader.config)
            write_buy_supplies(base, buy_sup_str)
            write_supply_sections(ini, base, buy_sup_str)
            write_discounts(ini, base, discounts_sec)
            write_trader_data(base, trader.data)

            total = total + 1
        end
    end

    send_log(x, "[END] export traders - %s traders exported", total)
end

function clear_stalkers()
    for i=1,65534 do local npc = alife_object(i) if npc and IsStalker(npc) then safe_release_manager.release(npc)  end end
end

function debug_cmd_list.cmd.export_traders_mapping(_, txt, x)
    send_log(x, "[START] export traders mapping")

    local smart_location_prefix = {
        ["agr"] = "agroprom",
        ["bar"] = "bar",
        ["bun"] = "bunker",
        ["ds2"] = "darkscape",
        ["val"] = "darkvalley",
        ["cit"] = "dead_city",
        ["dead"] = "dead_city",
        ["esc"] = "escape",
        ["gar"] = "garbage",
        ["gen"] = "generators",
        ["jup"] = "jupiter",
        ["katacomb"] = "katacomb_hospital",
        ["x162"] = "labx16",
        ["dar"] = "labx18",
        ["lim"] = "limansk",
        ["lx8"] = "lx8",
        ["mar"] = "marsh",
        ["mil"] = "military",
        ["mlr"] = "mlr",
        ["pol"] = "pole",
        ["kbo"] = "pripyat",
        ["pri"] = "pripyat",
        ["rad"] = "radar",
        ["red"] = "red_forest",
        ["ros"] = "rostok",
        ["sar"] = "sarcofag",
        ["aes"] = "stancia_1",
        ["aes2"] = "stancia_2",
        ["trc"] = "trucks_cemetery",
        ["pas"] = "underpass",
        ["warlab"] = "warlab",
        ["yan"] = "yantar",
        ["zat"] = "zaton",
        --["lain"] = "lain" -- unknown level
    }

    -- Reverse map: normalized trade config path -> traders.section
    local config_to_section = {}
    for _, t in ipairs(traders) do
        config_to_section[t.config:lower():gsub("/", "\\")] = t.section
    end

    -- Step 1: Load squad_descr and build smart_name -> { {story_id, npc} } map
    local squad_ini = ini_file("misc\\squad_descr\\squad_descr.ltx")
    if not squad_ini then
        send_log(x, "export traders mapping - ERROR: squad_descr.ltx not found")
        return
    end

    local smart_stories = {}
    build_character_blacklist()
    printf("export traders mapping - loading squad_descr.ltx")
    squad_ini:section_for_each(function(section)
        local squad_story_id = squad_ini:r_string_ex(section, "story_id")

        local npc_list = squad_ini:r_string_ex(section, "npc") or ""
        local npc_array = str_explode(npc_list, ",")
        for _, npc in ipairs(npc_array) do
            local character_profile = ini_sys:r_string_ex(npc, "character_profile") or ""
            if character_blacklist[character_profile] then
                printf("export traders mapping - skipping squad [%s] because it references blacklisted character [%s]", section, npc:trim())
                return
            end
        end

        local npc_sections_str = squad_ini:r_string_ex(section, "npc") or ""
        local npc_sections = str_explode(npc_sections_str, ",")
        local target_str = squad_ini:r_string_ex(section, "target_smart") or ""
        printf("export traders mapping - processing squad section [%s] story_id=%s target_smart=%s npc_sections=[%s]", section, squad_story_id or "", target_str, npc_sections_str)

        for _, npc_section in pairs(npc_sections) do
            local story_id = squad_story_id or ini_sys:r_string_ex(npc_section, "story_id") or ""
            if story_id == "" then
                printf("export traders mapping - WARNING: no story_id found for npc section [%s], skipping", npc_section)
                return
            end
            for _, entry in ipairs(parse_condlist(target_str)) do
            local smart = entry.section
            if smart and smart ~= "" and smart ~= "nil" then
                printf("export traders mapping - squad section [%s] story_id=%s target_smart=%s", section, story_id, smart)
                if not smart_stories[smart] then smart_stories[smart] = {} end
                local dupe = false
                for _, e in ipairs(smart_stories[smart]) do
                    if e.story_id == story_id then dupe = true; break end
                end
                if not dupe then
                    smart_stories[smart][#smart_stories[smart] + 1] = { story_id = story_id, npc = npc_section }
                end
            end
        end
        end
    end)

    -- Step 2: Walk each smart -> exclusive -> logic files -> logic@ sections with trade
    local result = {
        ["stalker_sidorovich"] = { "esc_m_trader"}
    }
    local loaded_logic = {}
    -- pending: { npc_sec, trader_section, story_id, suitable_str }
    -- processed sequentially with NPC spawn + online wait
    local pending = {}

    local actor_pos = db.actor:position()
    local actor_lvid = db.actor:level_vertex_id()
    local actor_gvid = db.actor:game_vertex_id()

    local function add_story_id(trader_section, story_id)
        if not result[trader_section] then result[trader_section] = {} end
        for _, s in ipairs(result[trader_section]) do
            if s == story_id then return end
        end
        result[trader_section][#result[trader_section] + 1] = story_id
    end

    local function process_logic_file(logic_path, squad_entries)
        local norm = logic_path:gsub("/", "\\"):lower()
        if loaded_logic[norm] == nil then
            loaded_logic[norm] = ini_file("scripts\\" .. logic_path:gsub("/", "\\")) or false
        end
        local logic_ini = loaded_logic[norm]
        if not logic_ini then return end

        logic_ini:section_for_each(function(sec)
            if not sec:find("^logic@") then return end
            local trade = logic_ini:r_string_ex(sec, "trade")
            if not trade or trade == "" then return end

            local trader_section = config_to_section[trade:lower():gsub("/", "\\")]
            if not trader_section then return end

            local suitable_str = logic_ini:r_string_ex(sec, "suitable")
            if suitable_str and suitable_str ~= "" then
                for _, entry in ipairs(squad_entries) do
                    if entry.npc and entry.npc ~= "" then
                        local npc_sections = str_explode(entry.npc, ",")
                        for _, v in pairs(npc_sections) do
                            pending[#pending + 1] = {
                                npc_sec       = v,
                                trader_section = trader_section,
                                story_id      = entry.story_id,
                                suitable_str  = suitable_str,
                            }
                        end
                    end
                end
            else
                for _, entry in ipairs(squad_entries) do
                    add_story_id(trader_section, entry.story_id)
                end
            end
        end)
    end

    local missing_prefixes = {}
    for smart_name, squad_entries in pairs(smart_stories) do
        local prefix = smart_name:match("^([a-z0-9]+)_")
        if not prefix then
            printf("export traders mapping - WARNING: cannot extract location prefix from smart [%s], skipping", smart_name)
            missing_prefixes["nil"] = true
            goto continue
        end

        local location = prefix and smart_location_prefix[prefix]
        if location then
            local path = "scripts\\" .. location .. "\\smart\\" .. smart_name .. ".ltx"
            local smart_ini = ini_file(path)
            printf("Processing ini %s", path)
            if smart_ini and smart_ini:section_exist("exclusive") then
                local n = smart_ini:line_count("exclusive") or 0
                local seen_paths = {}
                for i = 0, n - 1 do
                    local _, _, logic_path = smart_ini:r_line("exclusive", i, "", "")
                    if logic_path and logic_path ~= "" and not seen_paths[logic_path] then
                        seen_paths[logic_path] = true
                        process_logic_file(logic_path, squad_entries)
                    end
                end
            end
        else
            missing_prefixes[prefix] = true
        end
        ::continue::
    end

    local missing_str = ""
    for prefix in pairs(missing_prefixes) do
        missing_str = missing_str .. (prefix or "nil") .. " "
    end
    if missing_str ~= "" then
        printf("export traders mapping - WARNING: missing location prefixes for: %s", missing_str)
    end

    -- Step 3: Write output (called after all pending suitable checks finish)
    local function write_output()
        local f = file_for_write("export_traders_mapping.csv")
        local sorted = {}
        for section in pairs(result) do sorted[#sorted + 1] = section end
        table.sort(sorted)
        for _, section in ipairs(sorted) do
            local ids = result[section]
            table.sort(ids)
            local row = { section }
            for _, id in ipairs(ids) do row[#row + 1] = id end
            write_csv(f, unpack(row))
        end
        f:close()
        send_log(x, "[END] export traders mapping - %s trader sections mapped", #sorted)
    end

    if #pending == 0 then
        write_output()
        return
    end

    -- Step 4: Process pending suitable checks in batches of 50.
    -- Each batch: spawn all uncached NPCs, wait 1s for online, evaluate suitable,
    -- then wait 1s and release all before starting the next batch.
    -- suitable_cache avoids re-spawning the same (npc_sec, condlist) pair twice.
    local suitable_cache = {}
    local pending_idx = 1
    local BATCH_SIZE = 20

    local function process_batch()
        if pending_idx > #pending then
            printf("export traders mapping - all pending suitable checks done, writing output")
            write_output()
            return
        end

        -- Consume up to BATCH_SIZE items; resolve cached ones immediately
        local batch_end = math.min(pending_idx + BATCH_SIZE - 1, #pending)
        local spawned = {}  -- { se_id, cache_key, suitable_str, p }

        printf("export traders mapping - batch [%s-%s / %s]", pending_idx, batch_end, #pending)

        while pending_idx <= batch_end do
            local p = pending[pending_idx]
            pending_idx = pending_idx + 1
            local remaining = #pending - (pending_idx - 1)
            local cache_key = p.npc_sec .. "||" .. p.suitable_str

            if suitable_cache[cache_key] ~= nil then
                printf("export traders mapping -   [%s remaining] cache hit %s: passed=%s", remaining, p.npc_sec, tostring(suitable_cache[cache_key]))
                if suitable_cache[cache_key] then
                    add_story_id(p.trader_section, p.story_id)
                end
            else
                local se_obj = alife_create(p.npc_sec, actor_pos, actor_lvid, actor_gvid)
                if not se_obj then
                    printf("export traders mapping -   [%s remaining] alife_create failed for %s, skipping", remaining, p.npc_sec)
                    suitable_cache[cache_key] = false
                else
                    printf("export traders mapping -   [%s remaining] spawned %s id=%s", remaining, p.npc_sec, se_obj.id)
                    spawned[#spawned + 1] = { se_id = se_obj.id, cache_key = cache_key, suitable_str = p.suitable_str, p = p }
                    -- Mark cache_key as in-progress so duplicate npc_sec in same batch don't re-spawn
                    suitable_cache[cache_key] = false
                end
            end
        end

        if #spawned == 0 then
            process_batch()
            return
        end

        -- Wait 1s for all spawned NPCs to come online, then evaluate suitable
        local function wait_for_batch_online()
            CreateTimeEvent("tmap_batch_online_" .. pending_idx, "delay_func", 1, function()
                local all_online = true
                for _, entry in ipairs(spawned) do
                    if not level.object_by_id(entry.se_id) then
                        all_online = false
                        break
                    end
                end
                if not all_online then
                    printf("export traders mapping -   batch not all online yet, retrying")
                    wait_for_batch_online()
                    return true
                end

                printf("export traders mapping -   batch online, evaluating %s NPCs", #spawned)
                for _, entry in ipairs(spawned) do
                    local obj = level.object_by_id(entry.se_id)
                    local cond = xr_logic.parse_condlist(obj, "suitable", "suitable", entry.suitable_str)
                    local passed = cond and xr_logic.pick_section_from_condlist(db.actor, obj, cond) == "true" or false
                    printf("export traders mapping -   id=%s npc=%s suitable=%s", entry.se_id, entry.p.npc_sec, tostring(passed))
                    suitable_cache[entry.cache_key] = passed
                    if passed then
                        add_story_id(entry.p.trader_section, entry.p.story_id)
                    end
                end

                -- Wait 1s then release all and start next batch
                printf("export traders mapping -   batch done, scheduling release of %s NPCs", #spawned)
                CreateTimeEvent("tmap_batch_release_" .. pending_idx, "delay_func", 1, function()
                    for _, entry in ipairs(spawned) do
                        printf("export traders mapping -   releasing id=%s", entry.se_id)
                        safe_release_manager.release(alife_object(entry.se_id))
                    end
                    process_batch()
                    return true
                end)
                return true
            end)
        end

        wait_for_batch_online()
    end

    process_batch()
end
