        ["af_quest_b14_twisted"] = true,
    }

    local used_in_crafting, craftable = export_artefacts_recipes()
    local perk_artefacts = get_perk_artifacts_list()

    local tbl = {}
    local cnt = 0
    ini_sys:section_for_each(function(section)
        if blacklist[section] or is_multiplayer_item(section) then
            return
        end
        local kind = ini_sys:r_string_ex(section, "kind") -- special class name for the sake of correct listing

        if kind and artefacts_kinds[kind] then
            send_log(x, "export artefact - %s", section)
            local artefact = {}
            artefact.name = translate_with_context(ini_sys:r_string_ex(section, "inv_name"), "item name for " .. section)
            artefact.description = (translate_with_context(ini_sys:r_string_ex(section, "description"), "description for " .. section) or ""):sanitize()
            artefact.cost = ini_sys:r_float_ex(section, "cost") or 0
            artefact.weight = floor_with_precision(ini_sys:r_float_ex(section, "inv_weight") or 0)
            artefact.tier = ini_sys:r_float_ex(section, "tier") or 0
            artefact.rank = ini_sys:r_float_ex(section, "af_rank") or 0
            artefact.is_junk = kind == "i_arty_junk" and "Y" or "N"
            artefact.has_perk = perk_artefacts[section] and "Y" or "N"
            artefact.perk_description = get_perk_description(section, perk_artefacts[section])
            artefact.jump_height = ini_sys:r_float_ex(section, "jump_height") or 0

            artefact.health_restore = get_artefact_stat_value(nil, section, "health_restore_speed")
            artefact.rad_restore = math.floor(get_artefact_stat_value(nil, section, "radiation_restore_speed") or 0)
            artefact.bleed_restore = (get_artefact_stat_value(nil, section, "bleeding_restore_speed") or 0) / 1000
            artefact.stamina_restore = to_percent_round((get_artefact_stat_value(nil, section, "power_restore_speed") or 0))
            artefact.satiety_restore = to_percent_string(getSatietyPercent(get_artefact_stat_value(nil, section, "satiety_restore_speed")))

            artefact.burn_immunity = to_percent_string(get_artefact_stat_value(nil, section, "burn_immunity") or 0)
            artefact.shock_immunity = to_percent_string(get_artefact_stat_value(nil, section, "shock_immunity") or 0)
            artefact.radiation_immunity = to_percent_string(get_artefact_stat_value(nil, section, "radiation_immunity") or 0)
            artefact.psychic_immunity = to_percent_string(get_artefact_stat_value(nil, section, "telepatic_immunity") or 0)
            artefact.chemical_burn_immunity = to_percent_string(get_artefact_stat_value(nil, section, "chemical_burn_immunity") or 0)

            artefact.rupture_immunity = to_percent_string(get_artefact_stat_value(nil, section, "wound_immunity") or 0)
            artefact.ballistic_immunity = to_percent_string(get_artefact_stat_value(nil, section, "fire_wound_immunity") or 0)
            artefact.explosion_immunity = to_percent_string(get_artefact_stat_value(nil, section, "explosion_immunity") or 0)
            artefact.impact_immunity = to_percent_string(get_artefact_stat_value(nil, section, "strike_immunity") or 0)

            artefact.weight_carried = math.floor(get_artefact_stat_value(nil, section, "additional_inventory_weight") or 0)

            artefact.burn_cap = to_percent_string(get_artefact_stat_value(nil, section, "burn_cap") or 0)
            artefact.shock_cap = to_percent_string(get_artefact_stat_value(nil, section, "shock_cap") or 0)
            artefact.telepatic_cap = to_percent_string(get_artefact_stat_value(nil, section, "telepatic_cap") or 0)
            artefact.chemical_burn_cap = to_percent_string(get_artefact_stat_value(nil, section, "chemical_burn_cap") or 0)

            artefact.rupture_cap = to_percent_string(get_artefact_stat_value(nil, section, "wound_cap") or 0)
            artefact.ballistic_cap = to_percent_string(get_artefact_stat_value(nil, section, "fire_wound_cap") or 0)
            artefact.explosion_cap = to_percent_string(get_artefact_stat_value(nil, section, "explosion_cap") or 0)
            artefact.impact_cap = to_percent_string(get_artefact_stat_value(nil, section, "strike_cap") or 0)

            artefact.used_in_crafting = used_in_crafting[section] and "Y" or "N"
            artefact.craftable = craftable[section] and "Y" or "N"

            tbl[section] = artefact
            icon_candidates[section] = true
            cnt = cnt + 1
        end
    end)

    local p_file = "export_artefacts.csv"
    local debug_file = file_for_write(p_file)

    local header = translate_headers({
        "~", "pda_encyclopedia_name", "st_data_export_description", "st_prop_weight", "st_upgr_cost", "pda_encyclopedia_tier", "ui_st_rank", "st_data_export_jump_height", "st_data_export_is_junk", "st_data_export_has_perk", "st_data_export_perk_description", "ui_inv_outfit_fire_wound_protection", "ui_inv_outfit_wound_protection", "ui_inv_outfit_burn_protection", "ui_inv_outfit_shock_protection", "ui_inv_outfit_chemical_burn_protection", "ui_inv_outfit_radiation_protection", "ui_inv_outfit_telepatic_protection", "ui_inv_outfit_strike_protection", "ui_inv_outfit_explosion_protection", "st_prop_restore_health", "ui_inv_satiety", "st_prop_restore_bleeding", "st_data_export_restore_radiation", "ui_inv_outfit_power_restore", "gamma_fire_wound_cap", "gamma_wound_cap", "gamma_burn_cap", "gamma_shock_cap", "gamma_chemical_burn_cap", "gamma_telepatic_cap", "gamma_strike_cap", "gamma_explosion_cap", "ui_inv_outfit_additional_weight", "st_data_export_used_in_crafting", "st_data_export_can_be_crafted" })
    write_csv_header(debug_file, header)
    local sorted_keys = sort_keys(tbl)
    for _, section in ipairs(sorted_keys) do
        local v = tbl[section]
        write_csv(debug_file,
                section, v.name, v.description, v.weight, v.cost, v.tier, v.rank, v.jump_height, v.is_junk, v.has_perk, v.perk_description, v.ballistic_immunity, v.rupture_immunity, v.burn_immunity, v.shock_immunity, v.chemical_burn_immunity, v.radiation_immunity, v.psychic_immunity, v.impact_immunity, v.explosion_immunity, v.health_restore, v.satiety_restore, v.bleed_restore, v.rad_restore, v.stamina_restore, v.ballistic_cap, v.rupture_cap, v.burn_cap, v.shock_cap, v.chemical_burn_cap, v.telepatic_cap, v.impact_cap, v.explosion_cap, v.weight_carried, v.used_in_crafting, v.craftable
        )
    end
    debug_file:close()

    send_log(x, "[END] export artefacts - %s total artefacts exported", cnt)
end

-- Craft category index to filename suffix mapping
local craft_category_files = {
    [1] = "device",
    [2] = "equipment",
    [3] = "repair",
    [4] = "upgrades",
    [5] = "medical",
    [6] = "ammo",
    [7] = "artefact",
    [8] = "furniture",
    [9] = "decoration",
}

function debug_cmd_list.cmd.export_craft_recipes(_, txt, x)
    send_log(x, "[START] export craft recipes")

    local ini = itms_manager.ini_craft
    local ind = 1
    local total_cnt = 0

    while ini:section_exist(tostring(ind)) do
        local ind_str = tostring(ind)
        local used_in_crafting, craftable = export_recipes(ind)

        local tbl = {}
        local cnt = 0
        for section, recipes in pairs(craftable) do
            for i, raw_recipe in ipairs(recipes) do
                local recipe = {}
                recipe.name = translate_with_context(ini_sys:r_string_ex(section, "inv_name"), "item name for " .. section)
                recipe.tool = raw_recipe.tool or ""
                recipe.rsp = raw_recipe.rsp or ""
                recipe.rsp_name = raw_recipe.rsp and ini_sys:section_exist(raw_recipe.rsp) and translate_with_context(ini_sys:r_string_ex(raw_recipe.rsp, "inv_name"), "item name for " .. raw_recipe.rsp) or ""
                recipe.ingr_1_name = raw_recipe[1] and ini_sys:r_string_ex(raw_recipe[1][1], "inv_name") and translate_with_context(ini_sys:r_string_ex(raw_recipe[1][1], "inv_name"), "item name for " .. raw_recipe[1][1]) or ""
                recipe.ingr_1_amt = raw_recipe[1] and raw_recipe[1][2] and "x" .. raw_recipe[1][2] or ""
                recipe.ingr_2_name = raw_recipe[2] and ini_sys:r_string_ex(raw_recipe[2][1], "inv_name") and translate_with_context(ini_sys:r_string_ex(raw_recipe[2][1], "inv_name"), "item name for " .. raw_recipe[2][1]) or ""
                recipe.ingr_2_amt = raw_recipe[2] and raw_recipe[2][2] and "x" .. raw_recipe[2][2] or ""
                recipe.ingr_3_name = raw_recipe[3] and ini_sys:r_string_ex(raw_recipe[3][1], "inv_name") and translate_with_context(ini_sys:r_string_ex(raw_recipe[3][1], "inv_name"), "item name for " .. raw_recipe[3][1]) or ""
                recipe.ingr_3_amt = raw_recipe[3] and raw_recipe[3][2] and "x" .. raw_recipe[3][2] or ""
                recipe.ingr_4_name = raw_recipe[4] and ini_sys:r_string_ex(raw_recipe[4][1], "inv_name") and translate_with_context(ini_sys:r_string_ex(raw_recipe[4][1], "inv_name"), "item name for " .. raw_recipe[4][1]) or ""
                recipe.ingr_4_amt = raw_recipe[4] and raw_recipe[4][2] and "x" .. raw_recipe[4][2] or ""
                for i = 1, 4 do
                    if raw_recipe[i] and raw_recipe[i][1] then
                        icon_candidates[raw_recipe[i][1]] = true
                    end
                end
                icon_candidates[section] = true

                tbl[section] = recipe
                cnt = cnt + 1
            end
        end

        local suffix = craft_category_files[ind] or tostring(ind)
        local p_file = "export_craft_" .. suffix .. ".csv"
        local debug_file = file_for_write(p_file)
        local header = translate_headers({
            "~", "pda_encyclopedia_name", "st_data_export_tool_tier", "st_data_export_recipe_requirement", "st_data_export_recipe_requirement_name",
            "#1", "st_data_export_disassemble_amount", "#2", "st_data_export_disassemble_amount", "#3", "st_data_export_disassemble_amount", "#4", "st_data_export_disassemble_amount" })
        write_csv_header(debug_file, header)
        local sorted_keys = sort_keys(tbl)
        for _, section in ipairs(sorted_keys) do
            local v = tbl[section]
            write_csv(debug_file,
                    section, v.name, v.tool, v.rsp, v.rsp_name,
                    v.ingr_1_name, v.ingr_1_amt, v.ingr_2_name, v.ingr_2_amt, v.ingr_3_name, v.ingr_3_amt, v.ingr_4_name, v.ingr_4_amt
            )
        end
        debug_file:close()

        send_log(x, "[PROGRESS] export craft recipes - category %s (%s) - %s recipes - see in Gamma\\Overwrite\\bin\\%s", ind, suffix, cnt, p_file)
        total_cnt = total_cnt + cnt
        ind = ind + 1
    end

    send_log(x, "[END] export craft recipes - %s total recipes exported across %s categories", total_cnt, ind - 1)
end

function debug_cmd_list.cmd.export_belt_attachments(_, txt, x)
    send_log(x, "[START] export belt attachments")

    local artefacts_kinds = {
        ["i_mutant_belt"] = true,
        ["i_attach"] = true,
        ["i_backpack"] = true,
        ["EQ_BAKPK"] = true,
    }

    local blacklist = {
        ["fieldcraft_plate_attch"] = true,
        ["test_container"] = true,
    }

    local whitelist = {
        ["kit_hunt"] = true,
    }

    local used_in_crafting, craftable = export_artefacts_recipes()

    local tbl = {}
    local cnt = 0
    ini_sys:section_for_each(function(section)
        if blacklist[section] or is_multiplayer_item(section) then
            return
        end
        local kind = ini_sys:r_string_ex(section, "kind") -- special class name for the sake of correct listing

        if kind and artefacts_kinds[kind] or whitelist[section] then
            send_log(x, "export belt attachment - %s", section)
            local belt_attachment = {}
            belt_attachment.name = translate_with_context(ini_sys:r_string_ex(section, "inv_name"), "item name for " .. section)
            belt_attachment.cost = ini_sys:r_float_ex(section, "cost") or 0
            belt_attachment.weight = floor_with_precision(ini_sys:r_float_ex(section, "inv_weight") or 0)
            belt_attachment.tier = ini_sys:r_float_ex(section, "tier") or 0
            belt_attachment.is_backpack = (kind == "i_backpack" or kind == "EQ_BAKPK") and "Y" or "N"
            belt_attachment.jump_height = ini_sys:r_float_ex(section, "jump_height") or 0
            belt_attachment.bonus_mutant_part_chance = to_percent_string(ini_sys:r_float_ex(section, "bonus_mutant_part_chance"))

            belt_attachment.health_restore = get_artefact_stat_value(nil, section, "health_restore_speed")
            belt_attachment.rad_restore = math.floor(get_artefact_stat_value(nil, section, "radiation_restore_speed") or 0)
            belt_attachment.bleed_restore = (get_artefact_stat_value(nil, section, "bleeding_restore_speed") or 0) / 1000
            belt_attachment.stamina_restore = to_percent_round(get_artefact_stat_value(nil, section, "power_restore_speed"))
            belt_attachment.satiety_restore = to_percent_string(getSatietyPercent(get_artefact_stat_value(nil, section, "satiety_restore_speed")))

            belt_attachment.burn_immunity = to_percent_string(get_artefact_stat_value(nil, section, "burn_immunity") or 0)
            belt_attachment.shock_immunity = to_percent_string(get_artefact_stat_value(nil, section, "shock_immunity") or 0)
            belt_attachment.radiation_immunity = to_percent_string(get_artefact_stat_value(nil, section, "radiation_immunity") or 0)
            belt_attachment.psychic_immunity = to_percent_string(get_artefact_stat_value(nil, section, "telepatic_immunity") or 0)
            belt_attachment.chemical_burn_immunity = to_percent_string(get_artefact_stat_value(nil, section, "chemical_burn_immunity") or 0)

            belt_attachment.rupture_immunity = to_percent_string(get_artefact_stat_value(nil, section, "wound_immunity") or 0)
            belt_attachment.ballistic_immunity = to_percent_string(get_artefact_stat_value(nil, section, "fire_wound_immunity") or 0)
            belt_attachment.explosion_immunity = to_percent_string(get_artefact_stat_value(nil, section, "explosion_immunity") or 0)
            belt_attachment.impact_immunity = to_percent_string(get_artefact_stat_value(nil, section, "strike_immunity") or 0)

            belt_attachment.weight_carried = math.floor(get_artefact_stat_value(nil, section, "additional_inventory_weight") or 0)

            tbl[section] = belt_attachment
            icon_candidates[section] = true
            cnt = cnt + 1
        end
    end)

    local p_file = "export_belt_attachments.csv"
    local debug_file = file_for_write(p_file)
    local header = translate_headers({
        "~", "pda_encyclopedia_name", "st_prop_weight", "st_upgr_cost", "pda_encyclopedia_tier", "st_data_export_is_backpack", "st_data_export_jump_height", "st_data_export_bonus_mutant_part_chance", "ui_inv_outfit_fire_wound_protection", "ui_inv_outfit_wound_protection", "ui_inv_outfit_burn_protection", "ui_inv_outfit_shock_protection", "ui_inv_outfit_chemical_burn_protection", "ui_inv_outfit_radiation_protection", "ui_inv_outfit_telepatic_protection", "ui_inv_outfit_strike_protection", "ui_inv_outfit_explosion_protection", "st_prop_restore_health", "ui_inv_satiety", "st_prop_restore_bleeding", "st_data_export_restore_radiation", "ui_inv_outfit_power_restore", "ui_inv_outfit_additional_weight" })
    write_csv_header(debug_file, header)
    local sorted_keys = sort_keys(tbl)
    for _, section in ipairs(sorted_keys) do
        local v = tbl[section]
        write_csv(debug_file,
                section, v.name, v.weight, v.cost, v.tier, v.is_backpack, v.jump_height, v.bonus_mutant_part_chance, v.ballistic_immunity, v.rupture_immunity, v.burn_immunity, v.shock_immunity, v.chemical_burn_immunity, v.radiation_immunity, v.psychic_immunity, v.impact_immunity, v.explosion_immunity, v.health_restore, v.satiety_restore, v.bleed_restore, v.rad_restore, v.stamina_restore, v.weight_carried
        )
    end
    debug_file:close()

    send_log(x, "[END] export belt attachments - %s total attachments exported", cnt)
end

local blacklist_ammo = {
    ["_knife"] = true,
    ["_binoc"] = true,
    ["_base$"] = true,
    ["_dyno$"] = true,
    ["_batteries"] = true,
    ["^mp_"] = true,
    ["_bad$"] = true,
    ["_verybad$"] = true,
    ["_heli$"] = true,
    ["_parts$"] = true,
    ["^casing_"] = true,
    ["^powder_"] = true,
    ["^bullet_"] = true,
}

function is_blacklisted_ammo(section)
    for black, _ in pairs(blacklist_ammo) do
        if string.find(section, black) then
            return true
        end
    end
    return false
end

function get_weapon_caliber(ammo_class)
    --printf("ammo_class: %s", ammo_class)
    local ammo_tbl = str_explode(ammo_class, ",")
    if #ammo_tbl == 0 then
        return ""
    end
    local ammo_list = ""

    for i, ammo in ipairs(ammo_tbl) do
        --printf("ammo: %s", ammo)
        if is_blacklisted_ammo(ammo) then
            goto continue
        end

        local ammo_name = sanitize_ammo_name(translate_with_context(ini_sys:r_string_ex(ammo, "inv_name"), "item name for " .. ammo))
        if ammo_list == "" then
            ammo_list = ammo_name
        else
            local space = headers_mode == 0 and " " or ""
            ammo_list = ammo_list .. ";" .. space .. ammo_name
        end
        ::continue::
    end

    return ammo_list
end

function armor_to_class(val)
    if (val < 11) then
        val = 0
    elseif ((val >= 11) and (val < 19)) then
        val = 1
    elseif ((val >= 19) and (val < 30)) then
        val = 2
    elseif ((val >= 30) and (val < 39)) then
        val = 3
    elseif ((val >= 39) and (val < 46)) then
        val = 4
    elseif ((val >= 46) and (val < 55)) then
        val = 5
    else
        val = 6
    end

    return val
end

function get_weapon_br_stats(ammo_class)
    local brs = {
        "", "", "", "", "", "", ""
    }
    local ammo_tbl = str_explode(ammo_class, ",")
    --printf("ammo_class: %s", ammo_class)
    for i, ammo in ipairs(ammo_tbl) do
        local ap = ini_sys:r_float_ex(ammo, "k_ap") or 0
        --printf("%s %s", ammo, ap)
        ap = ap * 10 * 100 * get_game_difficulty_multiplier()
        local br = armor_to_class(ap)
        --printf("%s, %s", br, brs[br + 1])
        if br > 0 and (not brs[br + 1] or brs[br + 1] == "" or brs[br + 1] < ap) then
            brs[br + 1] = ap
        end
    end
    --printf(brs[7])
    return brs[1], brs[2], brs[3], brs[4], brs[5], brs[6], brs[7]
end

function get_weapon_repair_label(repair_type)
    if repair_type == "pistol" then
        return "A"
    elseif repair_type == "shotgun" then
        return "B"
    elseif repair_type == "rifle_5" then
        return "C"
    elseif repair_type == "rifle_7" then
        return "D"
    end
    return "N/A"
end

local weapon_kinds = {
    ["w_pistol"] = "pistol",
    ["w_shotgun"] = "shotgun",
    ["w_smg"] = "smg",
    ["w_rifle"] = "rifle",
    ["w_sniper"] = "sniper",
    ["w_explosive"] = "explosive"
}

function is_weapon_modification(section)
    local class = ini_sys:r_string_ex(section, "class")
    local kind = ini_sys:r_string_ex(section, "kind")
    if kind == "" then kind = class end
    if kind and weapon_kinds[kind] then
        local weapon_class = ini_sys:r_string_ex(section, "weapon_class")
        if kind == "w_explosive" and (not weapon_class or weapon_class == "") then
            return true
        end
        local parent_section = ini_sys:r_string_ex(section, "parent_section")
        if parent_section and section ~= parent_section then
            return true
        end
    end
    return false
end

function debug_cmd_list.cmd.export_weapons(_, txt, x)
    send_log(x, "[START] export weapons")

    local blacklist = {
        ["wpn_colt_kimber"] = true,
        ["wpn_cz75_auto"] = true,
        ["wpn_cz52"] = true,
        ["wpn_steyr_scout"] = true, --crash
    }

    local leftToProcess = 0
   -- Build queue of sections to export
    local sections_queue = {}
    ini_sys:section_for_each(function(section)
        if blacklist[section] or is_multiplayer_item(section) then
            return
        end

        local class = ini_sys:r_string_ex(section, "class")
        local kind = ini_sys:r_string_ex(section, "kind")
        if kind == "" then kind = class end
        if kind and weapon_kinds[kind] and not is_weapon_modification(section) then
            table.insert(sections_queue, section)
            leftToProcess = leftToProcess + 1
        end
    end)

    local tbl = {}
    local cnt = 0
    local item_id

    local pos = db.actor:position()
    local lvid = db.actor:level_vertex_id()
    local gvid = db.actor:game_vertex_id()
    local id = AC_ID
    local se_obj

    ui_inventory.start("inventory", nil)
    local GUI = ui_inventory.GUI
    local slot_cells = GUI.slot_cell
    local onehanded_slots = {
        1,4,5,6,8,9
    }
    local allowed_slots = {}
    for _, slot in pairs(onehanded_slots) do
        local cells = slot_cells[slot]
        for _, slot_idx in pairs(cells) do
            allowed_slots[slot_idx] = true
        end
    end
    GUI:Close()

    local function process_queue(idx, itr)
        if idx > #sections_queue then
            send_log(x, "[END] export weapons - %s total exported", cnt)
            return true
        end
        local section = sections_queue[idx]
        printf("export weapons - processing %s: try %s  %s of %s", section, itr, idx, #sections_queue)
        local class = ini_sys:r_string_ex(section, "class")
        local kind = ini_sys:r_string_ex(section, "kind")
        if kind == "" then kind = class end
        kind = weapon_kinds[kind]
        if not tbl[kind] then tbl[kind] = {} end
        if not item_id then
            se_obj = alife_create_item(section, { pos, lvid, gvid, id })
            if not se_obj then
                printf("export weapon - %s, alife_create_item failed, retrying", section)
                process_queue(idx, itr + 1)
                return true
            end
            cnt = cnt + 1
            item_id = se_obj.id
        else
            printf("export weapon - %s, item_id already set to %s", section, item_id)
        end
        local delay = 0
        printf("export weapon - %s, start", section)
        -- Wait for item to come offline, then export
        CreateTimeEvent("export_weapon_" .. section .. itr, "delay_func", delay, function()
            local obj = level.object_by_id(item_id)
            if not obj then
                printf("export weapon - %s, object not found, retrying", section)
                process_queue(idx, itr + 1)
                return true
            end
            -- Now offline, export parameters
            local weapon = {}
            weapon.name = translate_with_context(ini_sys:r_string_ex(section, "inv_name"), "item name for " .. section)
            weapon.description = (translate_with_context(ini_sys:r_string_ex(section, "description"), "description for " .. section) or ""):sanitize()
            weapon.cost = ini_sys:r_float_ex(section, "cost") or 0
            weapon.weight = floor_with_precision(ini_sys:r_float_ex(section, "inv_weight") or 0)
            local repair_type = ini_sys:r_string_ex(section, "repair_type") or ""
            weapon.repair_label = get_weapon_repair_label(repair_type)

            weapon.single_handed = ini_sys:r_float_ex(section, "slot") or -1
            weapon.single_handed = allowed_slots[weapon.single_handed] and "Y" or "N"

            weapon.accuracy = to_percent_floor(get_weapon_stat_value(obj, section, "accuracy"))
            weapon.handling = to_percent_floor(get_weapon_stat_value(obj, section, "handling"))
            weapon.fire_rate = get_weapon_stat_value(obj, section, "fire_rate")
            weapon.ammo_mag_size = get_weapon_stat_value(obj, section, "ammo_mag_size")
            weapon.max_range = get_weapon_stat_value(obj, section, "max_range")
            weapon.speed = math.floor(get_weapon_stat_value(obj, section, "speed"))
            weapon.reliability = to_percent_floor(get_weapon_stat_value(obj, section, "reliability"))
            weapon.recoil = math.floor(get_weapon_stat_value(obj, section, "recoil"))
            local ammo_class = ini_sys:r_string_ex(section, "ammo_class") or ""
            weapon.caliber = get_weapon_caliber(ammo_class)

            local alt_calibers_cnt = 1
            local alt_calibers = {}
            local tree = utils_item.get_upgrades_tree(section)
            for row, v in pairs(tree) do
                for col, w in pairs(v) do
                    local sec = w.section
                    local upgrade_sec = ini_sys:r_string_ex(sec, "section")
                    if upgrade_sec then
                        local ammo_class = ini_sys:r_string_ex(upgrade_sec, "ammo_class")
                        if ammo_class then
                            alt_calibers[alt_calibers_cnt] = get_weapon_caliber(ammo_class)
                            alt_calibers_cnt = alt_calibers_cnt + 1
                        end
                    end
                end
            end

            local alt_calibers_str = ""
            for i, v in ipairs(alt_calibers) do
                if alt_calibers_str == "" then
                    alt_calibers_str = v
                else
                    alt_calibers_str = alt_calibers_str .. "; " .. v
                end
            end

            weapon.alt_caliber = alt_calibers_str
            weapon.hit_power = ui_wpn_params.read_float(section, "", "hit_power")

            weapon.br1, weapon.br2, weapon.br3, weapon.br4, weapon.br5, weapon.br6, weapon.br7 = get_weapon_br_stats(ammo_class)
            tbl[kind][section] = weapon
            icon_candidates[section] = true
            alife_release(se_obj)
            send_log(x, "export weapon - %s, done", section)
            leftToProcess = leftToProcess - 1
            item_id = nil
            process_queue(idx + 1, 0)
            return true
        end)
        return true
    end

    -- Start processing the queue
    process_queue(1, 0)

    retry_event("export_weapons_total_", 5, function()
        if leftToProcess > 0 then
            send_log(x, "export weapons - %s weapons still to do", leftToProcess)
            return false
        end

        for weapon_type, weapons in pairs(tbl) do
            local type_cnt = 0
            local p_file = "export_weapons_" .. weapon_type .. ".csv"
            local debug_file = file_for_write(p_file)

            if (debug_file == nil) then
                send_log(x, "Failed to create/open file %s", p_file)
                debug_file:close()
                return true
            end

            local header = translate_headers({
                "~", "pda_encyclopedia_name", "st_data_export_description", "st_prop_weight", "st_upgr_cost", "ui_mm_repair", "st_data_export_single_handed", "ui_inv_accuracy", "ui_inv_handling", "ui_inv_rate_of_fire", "ui_ammo_count", "ui_inv_wrange", "ui_inv_bspeed", "ui_inv_reli", "ui_inv_recoil", "ui_ammo_types", "st_data_export_ammo_types_alt", "st_data_export_hit_power", "BR1", "BR2", "BR3", "BR4", "BR5", "BR6", "BR7" })
            write_csv_header(debug_file, header)
            local sorted_keys = sort_keys(weapons)
            for _, section in ipairs(sorted_keys) do
                local w = weapons[section]
                write_csv(debug_file,
                        section, w.name, w.description, w.weight, w.cost, w.repair_label, w.single_handed, w.accuracy, w.handling, w.fire_rate, w.ammo_mag_size, w.max_range, w.speed, w.reliability, w.recoil, w.caliber, w.alt_caliber, w.hit_power, w.br1, w.br2, w.br3, w.br4, w.br5, w.br6, w.br7)
                type_cnt = type_cnt + 1
            end
            debug_file:close()
            send_log(x, "[END] export weapons - %s weapons exported - see %s", type_cnt, p_file)
        end

        send_log(x, "[END] export weapons - %s total weapons exported", cnt)
        return true
    end)
end

function get_heavy_attack_damage(obj, sec)
    local id = obj and obj:id()
    local hit_power = ini_sys:r_float_ex(sec, "hit_power_2") or 0
    local ammo_list = utils_item.get_ammo(sec, id)
    --printf("get_heavy_attack_damage - %s, hit_power %s, ammo_list %s", sec, hit_power, ammo_list[1])
    if ammo_list[1] then
        local k_hit = ini_sys:r_float_ex(ammo_list[1], "k_hit") or 1
        hit_power = (hit_power ~= 0) and (k_hit * hit_power) or k_hit
    end

    --printf("get_heavy_attack_damage - %s, hit_power %s", sec, hit_power)

    return normalize(hit_power, 0, 1.5)
end

function prop_damage(obj, sec, name)
    local hp_table = {}
    local values = {}
    local powers = {}
    local hit_power = 0

    if (not name) then
        return 0
    end

    hp_table = SYS_GetParam(0, obj and obj:section() or sec, name) or nil
    if hp_table ~= nil then
        values = str_explode(hp_table, ",")
        for i = 1, #values do
            powers[#powers + 1] = tonumber(values[i])
        end

        if powers ~= nil then
            hit_power = powers[game_difficulties.get_game_factor("actor_immunities") or 3] or 0
        end
    end

    return round_idp(hit_power * 100, 1)
end

function debug_cmd_list.cmd.export_melee(_, txt, x)
    send_log(x, "[START] export melee")

    local weapon_kinds = {
        ["w_melee"] = "melee",
        ["WP_KNIFE"] = "melee",
    }

    local blacklist = {
        ["wpn_axe2"] = true,
    }

    local tbl = {}
    local cnt = 0
    local counter = 0
    ini_sys:section_for_each(function(section)
        if blacklist[section] or is_multiplayer_item(section) or string.find(section, "animation") then
            return
        end

        local kind = ini_sys:r_string_ex(section, "kind") -- special class name for the sake of correct listing

        if kind and weapon_kinds[kind] then
            kind = weapon_kinds[kind]
            if not tbl[kind] then
                tbl[kind] = {}
            end

            local pos = db.actor:position()
            local lvid = db.actor:level_vertex_id()
            local gvid = db.actor:game_vertex_id()
            local id = AC_ID

            local se_obj
            se_obj = alife_create_item(section, { pos, lvid, gvid, id })

            if not se_obj then
                printf("No server object made for [%s]", section)
                --send_log(x,  "No server object made for [%s]", section)
                return
            end
            cnt = cnt + 1
            counter = counter + 1
            local id = se_obj.id

            send_log(x, "export melee - %s, start", section)
            retry_event("export_melee_" .. section .. "_", 2, function(section, id)
                local obj = level.object_by_id(id)
                if not obj then
                    --send_log(x, "export weapon - %s, still online", section)
                    return false
                end

                --send_log(x, "export weapon - %s, back offline", section)
                local weapon = {}
                weapon.name = translate_with_context(ini_sys:r_string_ex(section, "inv_name"), "item name for " .. section)
                weapon.description = (translate_with_context(ini_sys:r_string_ex(section, "description"), "description for " .. section) or ""):sanitize()
                weapon.cost = ini_sys:r_float_ex(section, "cost") or 0
                weapon.weight = floor_with_precision(ini_sys:r_float_ex(section, "inv_weight") or 0)
                weapon.max_range = get_weapon_stat_value(obj, section, "max_range")
                local ammo = ini_sys:r_string_ex(section, "ammo_class")
                weapon.br = (ammo and ini_sys:r_float_ex(ammo, "k_ap") or 0) * 10 * 100 * get_game_difficulty_multiplier()
                weapon.pelts_quality_min = zz_item_artefact.knifesm[section] and to_percent_string(zz_item_artefact.knifesm[section].min) or ""
                weapon.pelts_quality_max = zz_item_artefact.knifesm[section] and to_percent_string(zz_item_artefact.knifesm[section].max) or ""
                weapon.cuts_thick_skin = (section:match('wpn_knife$') or section:match('wpn_knife2$') or not string.find(section, "knife")) and "N" or "Y"
                weapon.light_attack_power = prop_damage(obj, section, "hit_power")
                weapon.heavy_attack_power = prop_damage(obj, section, "hit_power_2")

                tbl[kind][section] = weapon
                icon_candidates[section] = true
                alife_release(se_obj)
                send_log(x, "export melee - %s, done", section)
                counter = counter - 1
                return true
            end, section, id)
        end
    end)

    retry_event("export_melee_total_", 5, function()
        if counter > 0 then
            send_log(x, "export melee - %s weapons still to do", counter)
            return false
        end

        for weapon_type, weapons in pairs(tbl) do
            local type_cnt = 0
            local p_file = "export_weapons_" .. weapon_type .. ".csv"
            local debug_file = file_for_write(p_file)

            if (debug_file == nil) then
                send_log(x, "Failed to create/open file %s", p_file)
                debug_file:close()
                return true
            end

            local header = translate_headers({
                "~", "pda_encyclopedia_name", "st_data_export_description", "st_prop_weight", "st_upgr_cost", "st_data_export_light_attack_power", "st_data_export_heavy_attack_power", "BR", "ui_inv_wrange", "st_data_export_cuts_thick_skin", "st_data_export_pelts_quality_min", "st_data_export_pelts_quality_max" })
            write_csv_header(debug_file, header)
            local sorted_keys = sort_keys(weapons)
            for _, section in ipairs(sorted_keys) do
                local w = weapons[section]
                write_csv(debug_file,
                        section, w.name, w.description, w.weight, w.cost, w.light_attack_power, w.heavy_attack_power, w.br, w.max_range, w.cuts_thick_skin, w.pelts_quality_min, w.pelts_quality_max)
                type_cnt = type_cnt + 1
            end
            debug_file:close()
            send_log(x, "[END] export melee - %s melee exported - see %s", type_cnt, p_file)
        end
        send_log(x, "[END] export melee - %s total melee exported", cnt)
        return true
    end)
end

function is_multiplayer_item(section)
    local is_mp = string.find(section, "^mp_")
    return is_mp and true or false
end

function debug_cmd_list.cmd.export_explosives(_, txt, x)
    send_log(x, "[START] export explosives")

    local mines = {}
    for mine, id in pairs(txr_mines.FX_BY_SECTION) do
        mines[id] = txr_mines.EXPLOSIVE_SECTION_LOOKUP[mine]
        --printf("mine %s, id %s", mine, id)
    end

    local blacklist = {
        [""] = true,
        ["helicopter"] = true,
        ["mine_blow"] = true,
        ["new_tasks_addon_heli_strong"] = true,
        ["rpg_blow"] = true,
        ["rpg_new_blow"] = true,
    }

    local tbl = {}
    local cnt = 0
    ini_sys:section_for_each(function(section)
        if blacklist[section] or is_multiplayer_item(section) or string.find(section, "bad") or string.find(section, "helicopter_strong") or string.find(section, "helicopter_weak") then
            return
        end

        local kind = ini_sys:r_string_ex(section, "kind") -- special class name for the sake of correct listing
        local rocket_class = ini_sys:r_string_ex(section, "rocket_class")
        local fake_grenade_name = ini_sys:r_string_ex(section, "fake_grenade_name")
        local blast = ini_sys:r_float_ex(section, "blast")

        if rocket_class or fake_grenade_name or (kind and kind == "w_explosive" and blast) or mines[section] then
            local weapon_class = ini_sys:r_string_ex(section, "weapon_class")
            if weapon_class then
                --printf("export explosive - %s, weapon_class %s", section, weapon_class)
                return
            end
            local explosive = {}
            explosive.name = translate_with_context(ini_sys:r_string_ex(section, "inv_name"), "item name for " .. section)
            if not explosive.name or explosive.name == "" then
                return
            end
            explosive.description = (translate_with_context(ini_sys:r_string_ex(section, "description"), "description for " .. section) or ""):sanitize()

            explosive.cost = ini_sys:r_float_ex(section, "cost") or 0
            if explosive.cost == 0 then
                return
            end
            send_log(x, "export explosive - %s", section)
            explosive.weight = floor_with_precision(ini_sys:r_float_ex(section, "inv_weight") or 0)
            local explosive_section = nil
            if rocket_class then
                explosive_section = rocket_class
            elseif fake_grenade_name then
                explosive_section = fake_grenade_name
            elseif mines[section] then
                explosive_section = mines[section]
            elseif kind and kind == "w_explosive" then
                explosive_section = section
            else
                send_log(x, "export explosive - %s, no explosive section found", section)
                return
            end
            explosive.blast_power = ini_sys:r_float_ex(explosive_section, "blast") or 0
            explosive.blast_radius = ini_sys:r_float_ex(explosive_section, "blast_r") or 0
            explosive.frag_hit = ini_sys:r_float_ex(explosive_section, "frag_hit") or 0
            explosive.frags = ini_sys:r_float_ex(explosive_section, "frags") or 0
            explosive.delay = ini_sys:r_float_ex(explosive_section, "explode_duration") or 0

            tbl[section] = explosive
            icon_candidates[section] = true
            cnt = cnt + 1
        end
    end)

    local p_file = "export_explosives.csv"
    local debug_file = file_for_write(p_file)
    local header = translate_headers({
        "~", "pda_encyclopedia_name", "st_data_export_description", "st_prop_weight", "st_upgr_cost", "st_data_export_blast_power", "st_detonation_radius", "st_data_export_fragments", "st_data_fragment_damage", "st_detonation_time" })
    write_csv_header(debug_file, header)
    local sorted_keys = sort_keys(tbl)
    for _, section in ipairs(sorted_keys) do
        local v = tbl[section]
        write_csv(debug_file,
                section, v.name, v.description, v.weight, v.cost, v.blast_power, v.blast_radius, v.frags, v.frag_hit, v.delay
        )
    end
    debug_file:close()

    send_log(x, "[END] export explosives - %s total explosives exported", cnt)
end

--local difficulty_scaling = ballistics_mcm and ballistics_mcm.get_config("difficulty_scaling") or false
local difficulty_scaling = false  --see cxv_ammo_stats_tbl.difficulty_multiplier for other values
local difficulty_multiplier = {
    [1] = (difficulty_scaling and 1.3) or 1.0,
    [2] = (difficulty_scaling and 1.05) or 1.0,
    [3] = (difficulty_scaling and 0.90) or 1.0,
    [4] = (difficulty_scaling and 0.80) or 1.0,
}
function get_game_difficulty_multiplier()
    local game_num = 1

    if difficulty_scaling then
        local gameplay = alife_storage_manager.get_state().diff_game
        if not (type(gameplay) == "table") then
            -- for old saves
            alife_storage_manager.get_state().diff_game = {}
            alife_storage_manager.get_state().diff_game["type"] = game_num
            gameplay = alife_storage_manager.get_state().diff_game
        end

        game_num = gameplay["type"] or game_num
        if game_num > 4 then
            game_num = 4
        end                -- in case someone is using a custom difficulty
    end

    return difficulty_multiplier[game_num]
end

function get_ammo_br_stat(ammo_section)
    local brs = {
        "", "", "", "", "", "", ""
    }
    local ap = ini_sys:r_float_ex(ammo_section, "k_ap") or 0
    ap = ap * 10 * 100 * get_game_difficulty_multiplier() --see cxv_ammo_stats_tbl.difficulty_multiplier for other values
    local br = armor_to_class(ap)
    brs[br + 1] = ap
    return brs[1], brs[2], brs[3], brs[4], brs[5], brs[6], brs[7]
end

function normalize_mutant_ammo_mod(mod)
    if not mod then
        return 0.01
    end

    return mod / 0.85
end

function sanitize_ammo_name(name)
    if not name or name == "" then
        return ""
    end

    local words_to_remove = { "mm", "rounds", "grenade", "round", "shells", "Grenade", "shells", "warhead" }
    for _, word in ipairs(words_to_remove) do
        name = string.gsub(name, "%f[%a]" .. word .. "%f[%A]", "")
    end
    return name

end

function sanitize_value(name)
    if not name or name == "" then
        return ""
    end

    return '"' .. name .. '"'
end

function debug_cmd_list.cmd.export_ammo(_, txt, x)
    send_log(x, "[START] export ammo")

    local tbl = {}
    local cnt = 0
    ini_sys:section_for_each(function(section)
        if is_blacklisted_ammo(section) then
            return
        end

        local kind = ini_sys:r_string_ex(section, "kind") -- special class name for the sake of correct listing

        if kind == "w_ammo" then
            send_log(x, "export ammo - %s", section)
            local ammo = {}
            ammo.name = sanitize_ammo_name(translate_with_context(ini_sys:r_string_ex(section, "inv_name"), "item name for " .. section))
            ammo.description = (translate_with_context(ini_sys:r_string_ex(section, "description"), "description for " .. section) or ""):sanitize()
            ammo.cost = ini_sys:r_float_ex(section, "cost") or 0
            ammo.box_size = round(ini_sys:r_float_ex(section, "box_size") or 0)
            ammo.weight = floor_with_precision(ini_sys:r_float_ex(section, "inv_weight") or 0)
            ammo.projectiles = ini_sys:r_float_ex(section, "buck_shot") or 1
            ammo.damage = ini_sys:r_float_ex(section, "k_hit") or 0
            ammo.br1, ammo.br2, ammo.br3, ammo.br4, ammo.br5, ammo.br6, ammo.br7 = get_ammo_br_stat(section) --br1 is br0
            ammo.range = decimal_to_percent(ini_sys:r_float_ex(section, "k_dist"))
            ammo.velocity = decimal_to_percent(ini_sys:r_float_ex(section, "k_bullet_speed"))
            ammo.impulse = decimal_to_percent(ini_sys:r_float_ex(section, "k_impulse"))
            ammo.accuracy = decimal_to_percent(ini_sys:r_float_ex(section, "k_disp"))
            ammo.degr = decimal_to_percent(ini_sys:r_float_ex(section, "impair"))
            ammo.falloff = decimal_to_percent(ini_sys:r_float_ex(section, "k_air_resistance"))
            ammo.k_hit = ini_sys:r_float_ex(section, "k_hit") or 0
            ammo.k_ap = ini_sys:r_float_ex(section, "k_ap") or 0
            ammo.k_air_resistance = ini_sys:r_float_ex(section, "k_air_resistance") or 0
            tbl[section] = ammo
            icon_candidates[section] = true
            cnt = cnt + 1
        end
    end)

    local p_file = "export_ammo.csv"
    local debug_file = file_for_write(p_file)
    local header = translate_headers({
        "~", "pda_encyclopedia_name", "st_data_export_description", "st_prop_weight", "st_data_export_ammo_box_size", "st_upgr_cost", "BR1", "BR2", "BR3", "BR4", "BR5", "BR6", "BR7", "st_data_export_projectiles", "ui_inv_damage", "ui_inv_accuracy", "ui_inv_wrange", "st_data_export_falloff", "ui_inv_bspeed", "st_data_export_impulse", "st_data_export_weapon_degradation", "st_data_export_k_hit", "st_data_export_k_ap", "st_data_export_k_air_resistance" })
    write_csv_header(debug_file, header)
    local sorted_keys = sort_keys(tbl)
    for _, section in ipairs(sorted_keys) do
        local v = tbl[section]
        write_csv(debug_file,
                section, v.name, v.description, v.weight, v.box_size, v.cost, v.br1, v.br2, v.br3, v.br4, v.br5, v.br6, v.br7, v.projectiles, v.damage, v.accuracy, v.range, v.falloff, v.velocity, v.impulse, v.degr, v.k_hit, v.k_ap, v.k_air_resistance
        )
    end
    debug_file:close()

    send_log(x, "[END] export ammo - %s total ammo exported", cnt)
end

function debug_cmd_list.cmd.export_disassemble_table(_, txt, x)
    send_log(x, "[START] export disassemble table")

    local blacklist = {
        ["ammo"] = true,
        ["st_memory_stick_name"] = true,
        ["itm_guide_usb_1"] = true,
        ["itm_guide_usb_2"] = true,
    }

    local ini_parts = itms_manager.ini_parts
    local tbl_disassemble = {}
    local tbl_materials = {}
    local disassemble_count = 0
    local materials_count = 0
    ini_sys:section_for_each(function(section)
        for black, _ in pairs(blacklist) do
            if string.find(section, black) then
                return
            end
        end

        local partsRaw = ini_parts:r_string_ex("nor_parts_list", section)
        if partsRaw == nil then
            return
        end
        local parts_tbl = str_explode(partsRaw, ",")
        send_log(x, "export disassemble item - %s", section)

        local disassemble = {}
        local item_name = translate_with_context(ini_sys:r_string_ex(section, "inv_name"), "item name for " .. section)
        table.insert(disassemble, item_name)
        local parts = {}
        for i, part in ipairs(parts_tbl) do
            local repeat_number = tonumber(part)
            if repeat_number == nil then
                repeat_number = 1
            end
            for k = 1, repeat_number do
                if not parts[part] then
                    parts[part] = {}
                    parts[part].count = 0
                end
                parts[part].count = parts[part].count + 1
            end
        end

        local sortByCount = function(t, a, b)
            return t[a].count > t[b].count
        end

        for part_section, part in spairs(parts, sortByCount) do
            local part_name = translate_with_context(ini_sys:r_string_ex(part_section, "inv_name"), "item name for " .. part_section)
            local parts_count = part.count
            table.insert(disassemble, part_name)
            table.insert(disassemble, "x" .. parts_count)

            if not tbl_materials[part_section] then
                tbl_materials[part_section] = {}
                tbl_materials[part_section].name = part_name
                tbl_materials[part_section].results = {}
                materials_count = materials_count + 1
            end

            tbl_materials[part_section].results[section] = {}
            tbl_materials[part_section].results[section].name = item_name
            tbl_materials[part_section].results[section].count = parts_count
            icon_candidates[part_section] = true
        end

        tbl_disassemble[section] = disassemble
        icon_candidates[section] = true
        disassemble_count = disassemble_count + 1
    end)

    local disassembles_file_name = "export_disassemble_table.csv"
    local disassembles_file = file_for_write(disassembles_file_name)
    local header = translate_headers({
        "~", "pda_encyclopedia_name", "st_data_export_disassemble_result", "st_data_export_disassemble_amount", "st_data_export_disassemble_result", "st_data_export_disassemble_amount", "st_data_export_disassemble_result", "st_data_export_disassemble_amount", "st_data_export_disassemble_result", "st_data_export_disassemble_amount", "st_data_export_disassemble_result", "st_data_export_disassemble_amount", "st_data_export_disassemble_result", "st_data_export_disassemble_amount", "st_data_export_disassemble_result", "st_data_export_disassemble_amount", "st_data_export_disassemble_result", "st_data_export_disassemble_amount", "st_data_export_disassemble_result", "st_data_export_disassemble_amount", "st_data_export_disassemble_result", "st_data_export_disassemble_amount" })
    write_csv_header(disassembles_file, header)
    local sorted_keys = sort_keys(tbl_disassemble)
    for _, section in ipairs(sorted_keys) do
        local item = tbl_disassemble[section]
        local parts = { section }
        for i, materialOrCount in ipairs(item) do
            parts[#parts + 1] = materialOrCount
        end
        write_csv(disassembles_file, unpack(parts))
    end
    disassembles_file:close()

    send_log(x, "[PROGRESS-1] export disassemble - %s total disassembles exported - see in Gamma\\Overwrite\\bin\\export_disassemble_table.csv", disassemble_count)

    local materials_file_name = "export_disassembles_materials.csv"
    local materials_file = file_for_write(materials_file_name)
    local sortMaterialsByCount = function(t, a, b)
        return t[a].count > t[b].count
    end
    local fromStr = translate("st_data_export_from")
    header = translate_headers({
        "~", "pda_encyclopedia_name", "st_data_export_disassemble_amount", "st_data_export_disassemble_item", "st_data_export_disassemble_amount", "st_data_export_disassemble_item", "st_data_export_disassemble_amount", "st_data_export_disassemble_item", "st_data_export_disassemble_amount", "st_data_export_disassemble_item", "st_data_export_disassemble_amount", "st_data_export_disassemble_item", "st_data_export_disassemble_amount", "st_data_export_disassemble_item", "st_data_export_disassemble_amount", "st_data_export_disassemble_item", "st_data_export_disassemble_amount", "st_data_export_disassemble_item", "st_data_export_disassemble_amount", "st_data_export_disassemble_item", "st_data_export_disassemble_amount", "st_data_export_disassemble_item" })
    write_csv_header(materials_file, header)
    local sorted_keys = sort_keys(tbl_materials)
    for _, section in ipairs(sorted_keys) do
        local part = tbl_materials[section]
        local parts = { section, part.name or "None" }
        for i, result in spairs(part.results, sortMaterialsByCount) do
            parts[#parts + 1] = result.count .. " " .. fromStr
            parts[#parts + 1] = result.name
        end
        write_csv(materials_file, unpack(parts))
    end

    send_log(x, "[END] export materials - %s total materials exported", materials_count)
end

function debug_cmd_list.cmd.export_outfit_exchange(_, txt, x)
    send_log(x, "[START] export outfit exchange")

    local outfit_map = {}
    for variable, value in pairs(grok_armor_convert) do
        if not string.find(variable, "all_") then
            local reward
            local source_outfits = {}
            for prop, propValue in pairs(value) do
                if prop == "reward" then
                    reward = propValue
                elseif prop ~= "cost" then
                    source_outfits[prop] = true
                end
            end

            if reward and source_outfits then
                for outfit, _ in pairs(source_outfits) do
                    if not outfit_map[outfit] then
                        outfit_map[outfit] = {}
                    end
                    if not outfit_map[outfit]["rewards"] then
                        outfit_map[outfit]["rewards"] = {}
                        outfit_map[outfit]["community"] = ini_sys:r_string_ex(outfit, "community") or ""
                        outfit_map[outfit]["name"] = translate_with_context(ini_sys:r_string_ex(outfit, "inv_name"), "item name for " .. outfit)
                    end

                    table.insert(outfit_map[outfit]["rewards"], {
                        ["community"] = ini_sys:r_string_ex(reward, "community") or "",
                        ["reward"] = reward,
                        ["name"] = translate_with_context(ini_sys:r_string_ex(reward, "inv_name"), "item name for " .. reward)
                    })
                end
            end
        end
    end

    local communities = game_relations.factions_table
    table.sort(communities)

    local cnt = 0

    local file_name = "export_outfit_exchange.csv"
    local file = file_for_write(file_name)

    local community_map = {}
    for i, community in ipairs(communities) do
        community_map[community] = ""
    end

    local sortByFactionAndName = function(t, a, b)
        local faction_a = t[a]["community"]
        local faction_b = t[b]["community"]
        if faction_a == faction_b then
            return t[a]["name"] < t[b]["name"]
        else
            return faction_a < faction_b
        end
    end
    local headers = { "~", "pda_encyclopedia_name", "st_data_export_exchange_reward" }
    for i, community in ipairs(communities) do
        table.insert(headers, community)
    end
    local header = translate_headers(headers)
    write_csv_header(file, header)
    local unknown_str = translate("st_data_export_unknown")
    local sorted_keys = sort_keys(outfit_map)
    for _, section in ipairs(sorted_keys) do
        local data = outfit_map[section]
        local parts = { translate(data["community"], unknown_str, "translating community " .. data["community"] .. " for exchanges of " .. section), data["name"], "" }
        for i, reward in spairs(data["rewards"], sortByFactionAndName) do
            community_map[reward.community] = reward.name
            cnt = cnt + 1
        end
        for i, community in ipairs(communities) do
            parts[#parts + 1] = community_map[community] or "N/A"
        end
        write_csv(file, unpack(parts))
        for i, community in ipairs(communities) do
            community_map[community] = ""
        end
    end
    file:close()

    send_log(x, "[END] outfit exchange - %s total exchanges exported", cnt)
end

function debug_cmd_list.cmd.export_mutant_parts_prices(_, txt, x)
    send_log(x, "[START] export mutant parts prices")

    local fake_butcher
    local fake_sakharov

    local sim = alife()
    for i = 1, 65534 do
        local se_obj = sim:object(i)
        if (se_obj and se_obj.group_id ~= 65535) then
            if IsStalker(nil, se_obj:clsid()) then
                local npc = level.object_by_id(i)
                if npc then
                    if not fake_butcher then
                        fake_butcher = npc
                    elseif not fake_sakharov then
                        fake_sakharov = npc
                    end
                end
            end
        end
    end

    if not fake_butcher then
        send_log(x, "Unable to find any NPCs on level for faking Butcher")
        return
    end

    if not fake_sakharov then
        send_log(x, "Unable to find any NPCs on level for faking Sakharov")
        return
    end

    trade_manager.trade_init(fake_butcher, "items\\trade\\trade_stalker_butcher.ltx")
    trade_manager.update(fake_butcher)
    trade_manager.trade_init(fake_sakharov, "items\\trade\\trade_ecolog_sakharov.ltx")
    trade_manager.update(fake_sakharov)

    local GUI = ui_inventory.GUI

    GUI:TMode_InitProfile(fake_butcher)
    local butcher_profile = GUI.CC["actor_trade"].trade_profile
    printf("%s, %s, %s, %s, %s", butcher_profile.cfg, butcher_profile.list, butcher_profile.cond_factor, butcher_profile.cond_exponent, butcher_profile.discount)
    GUI:TMode_InitProfile(fake_sakharov)
    local sakharov_profile = GUI.CC["actor_trade"].trade_profile
    printf("%s, %s, %s, %s, %s", sakharov_profile.cfg, sakharov_profile.list, sakharov_profile.cond_factor, sakharov_profile.cond_exponent, sakharov_profile.discount)

    local cnt = 0
    local parts = {}
    local processing_counter = 0

    local pos = db.actor:position()
    local lvid = db.actor:level_vertex_id()
    local gvid = db.actor:game_vertex_id()
    local actor_id = AC_ID

    ini_sys:section_for_each(function(section)
        local type
        if string.find(section, "mutant_part") then
            type = 1
        end
        if string.find(section, "^hide") and not string.find(section, "absorbation") then
            type = 2
        end
        local has_cost = ini_sys:line_exist(section, "cost")
        if not type or not has_cost or section == "mutant_part_general_meat" then
            --printf("%s is not mutant part", section)
            return
        end

        local se_obj
        se_obj = alife_create_item(section, { pos, lvid, gvid, actor_id })

        if not se_obj then
            printf("No server object made for [%s]", section)
            send_log(x, "No server object made for [%s]", section)
            return
        end
        cnt = cnt + 1
        processing_counter = processing_counter + 1
        local id = se_obj.id

        send_log(x, "export mutant part price - %s, start", section)
        retry_event("export_mutant_part_price_" .. section .. "_", 2, function(section, id)
            local obj = level.object_by_id(id)
            if not obj then
                send_log(x, "export part - %s, still online", section)
                return false
            end
            if not obj.section then
                send_log(x, "export mutant part price - %s, failed", section)
                processing_counter = processing_counter - 1
                --send_log(x, "export weapon - %s, still online", section)
                alife_release(se_obj)
                return true
            end

            local part = {}
            part = {}
            part.type = type
            part.name = translate_with_context(ini_sys:r_string_ex(section, "inv_name"), "item name for " .. section)
            part.sakharov_price = math.floor(utils_item.get_item_cost(obj, sakharov_profile))
            part.butcher_price = math.floor(utils_item.get_item_cost(obj, butcher_profile))

            parts[section] = part
            alife_release(se_obj)
            send_log(x, "export mutant part price - %s, done", section)
            processing_counter = processing_counter - 1
            return true
        end, section, id)
    end)

    retry_event("export_mutant_part_price__total_", 5, function()
        if processing_counter > 0 then
            send_log(x, "export mutant parts prices - %s parts still to do", processing_counter)
            return false
        end

        local p_file = "export_mutant_parts_prices.csv"
        local file = file_for_write(p_file)

        if (file == nil) then
            send_log(x, "Failed to create/open file %s", p_file)
            return true
        end

        local sortByType = function(t, a, b)
            if t[a].type == t[b].type then
                return t[a].name < t[b].name
            end

            return t[a].type < t[b].type
        end
        local header = translate_headers({
            "~", "pda_encyclopedia_name", "yan_st_sakharov_name", "hunter_gar_trader_name" })
        write_csv_header(file, header)
        for section, part in spairs(parts, sortByType) do
            write_csv(file,
                    section, part.name, part.sakharov_price, part.butcher_price)
        end
        file:close()
        send_log(x, "[END] mutant parts prices - %s total parts exported", cnt)
        return true
    end)
end

function debug_cmd_list.cmd.export_mutant_profiles(_, txt, x)
    send_log(x, "[START] export mutant profiles")

    local function read_bone_mult(damage_sect, bone)
        local raw = ini_sys:r_string_ex(damage_sect, bone)
        if not raw then return nil end
        local vals = str_explode(raw, ",")
        return tonumber(vals[1])
    end

    local tbl = {}
    local cnt = 0

    ini_sys:section_for_each(function(section)
        local class = ini_sys:r_string_ex(section, "class")
        if not ui_debug_launcher.obj_to_spawn_classes[class] or not ui_debug_launcher.obj_to_spawn_classes[class]:find("Mutant") then return end

        local immunities_sect = ini_sys:r_string_ex(section, "immunities_sect")
        if not immunities_sect then return end
        local damage_sect = ini_sys:r_string_ex(section, "damage")
        if not damage_sect then return end

        -- skin_armor and hit_fraction: prefer protections_sect, fall back to section directly
        local protections_sect = ini_sys:r_string_ex(section, "protections_sect")
        local skin_armor    = (protections_sect and ini_sys:r_float_ex(protections_sect, "skin_armor"))
                           or ini_sys:r_float_ex(section, "skin_armor") or 0
        local hit_fraction  = (protections_sect and ini_sys:r_float_ex(protections_sect, "hit_fraction_monster"))
                           or ini_sys:r_float_ex(section, "hit_fraction_monster") or 0

        -- fire_wound_immunity from immunities section
        local fire_wound_immunity = ini_sys:r_float_ex(immunities_sect, "fire_wound_immunity") or 0

        -- hitzone multipliers: try specific bones, fall back to default
        local default_mult = read_bone_mult(damage_sect, "default") or 1
        local head  = read_bone_mult(damage_sect, "bip01_head") or default_mult
        local torso = read_bone_mult(damage_sect, "bip01_spine1")
                   or read_bone_mult(damage_sect, "bip01_spine") or default_mult
        local limbs = read_bone_mult(damage_sect, "bip01_l_thigh")
                   or read_bone_mult(damage_sect, "bip01_r_thigh")
                   or read_bone_mult(damage_sect, "bip01_l_upperarm") or default_mult
        local rear  = read_bone_mult(damage_sect, "bip01_pelvis") or default_mult

        tbl[section] = {
            skin_armor            = skin_armor,
            hit_fraction          = hit_fraction,
            fire_wound_immunity   = fire_wound_immunity,
            head                  = head,
            torso                 = torso,
            limbs                 = limbs,
            rear                  = rear,
        }
        cnt = cnt + 1
    end)

    local p_file = "export_mutant_profiles.csv"
    local f = file_for_write(p_file)
    local header = translate_headers({
        "~",
        "st_data_export_skin_armor", "st_data_export_hit_fraction", "st_data_export_fire_wound_immunity",
        "st_data_export_hitzone_head", "st_data_export_hitzone_torso",
        "st_data_export_hitzone_limbs", "st_data_export_hitzone_rear",
    })
    write_csv_header(f, header)

    local sorted_keys = sort_keys(tbl)
    for _, section in ipairs(sorted_keys) do
        local v = tbl[section]
        write_csv(f, section, v.skin_armor, v.hit_fraction, v.fire_wound_immunity,
                  v.head, v.torso, v.limbs, v.rear)
    end
    f:close()

    send_log(x, "[END] export mutant profiles - %s profiles written - see %s", cnt, p_file)
end

function get_weapon_kind(kind)
    if kind == "" then
        return ""
    end

    return "st_data_export_weapon_kind_" .. (weapon_kinds[kind] or "unknown")
end

function debug_cmd_list.cmd.export_weapon_drop_sources(_, txt, x)
    send_log(x, "[START] export weapon drop sources")

    local skip_sections = {
        ['skip_npcs'] = true,
        ['scope_blacklist'] = true,
        ['weapon_scope_blacklist'] = true,
        ['loadouts_per_name'] = true,
        ['default'] = true,
    }

    local skip_drop_sections = {
        "ammo",
    }

    local factions = {}

    local sources = {}
    local drop_ini = ini_file("items\\settings\\npc_loadouts\\npc_loadouts.ltx")
    drop_ini:section_for_each(function(section)
        if skip_sections[section] then
            return
        end

        if not drop_ini:line_exist(section, "primary") then
            return
        end

        local n = drop_ini:line_count(section) or 0
        local id, value, drop_section, m, tmp, gun_section, faction, rank, tmpfk
        if (n > 0) then
            for i = 0, n - 1 do
                _, _, drop_section = drop_ini:r_line(section, i, "", "")

                for _, s in pairs(skip_drop_sections) do
                    if string.find(drop_section, s) then
                        printf("Skipping drop section %s", drop_section)
                        goto skip_section
                    end
                end

                tmpfk = str_explode(section, '_')
                if tmpfk[1] == "loadout" then
                    faction = tmpfk[2] or ""
                    rank = tmpfk[3] or "unknown"
                else
                    faction = tmpfk[1] or ""
                    rank = tmpfk[2] or "any"
                end
                printf("section %s, faction %s, rank %s", section, faction, rank)

                m = drop_ini:line_count(drop_section) or 0
                for j = 0, m - 1 do
                    _, id, value = drop_ini:r_line_ex(drop_section, j, "", "")
                    tmp = str_explode(id, ":")
                    if tmp and tmp[1] and ini_sys:section_exist(tmp[1]) then
                        gun_section = tmp[1]
                        if not sources[gun_section] then
                            sources[gun_section] = {}
                        end

                        if not sources[gun_section][faction] then
                            sources[gun_section][faction] = {}
                        end

                        factions[faction] = true

                        if not sources[gun_section][faction]["ranks"] then
                            sources[gun_section][faction]["ranks"] = {}
                        end
                        sources[gun_section][faction]["ranks"][rank] = true
                    else
                        printe("! ERROR: NPC Loadouts Export | something is wrong in [%s] - %s (%s) = %s and %s. Full is %s", section, tmp[1], id)
                    end
                end

                ::skip_section::
            end
        end
    end)

    local cnt = 0
    local file_name = "export_weapon_drop_sources.csv"
    local file = file_for_write(file_name)

    local factions_sorted = {}
    for faction, _ in pairs(factions) do
        table.insert(factions_sorted, faction)
    end
    table.sort(factions_sorted)

    local rank_positions = {
        ["any"] = 0,
        ["novice"] = 1,
        ["trainee"] = 2,
        ["experienced"] = 3,
        ["professional"] = 4,
        ["veteran"] = 5,
        ["expert"] = 6,
        ["master"] = 7,
        ["legend"] = 8,
        ["unknown"] = 9,
    }
    local sortByRank = function(t, a, b)
        return (rank_positions[a] or 999) < (rank_positions[b] or 999)
    end

    local headers = { "~", "st_ui_dbg_spawn_type", "pda_encyclopedia_name"}
    for i, community in ipairs(factions_sorted) do
        table.insert(headers, community)
    end
    local header = translate_headers(headers)
    write_csv_header(file, header)
    local value = ""
    local gun_name, kind, ranks
    local sorted_keys = sort_keys(sources)
    for _, gun in ipairs(sorted_keys) do
        local gun_factions = sources[gun]
        gun_name = translate_with_context(ini_sys:r_string_ex(gun, "inv_name"), "item name for " .. gun)
        kind = translate_with_context(get_weapon_kind(ini_sys:r_string_ex(gun, "kind")), "weapon kind for " .. gun)
        local parts = { gun, kind, gun_name }
        for i, faction in pairs(factions_sorted) do
            if gun_factions[faction] and gun_factions[faction]["ranks"] then
                ranks = ""
                for rank, _ in spairs(gun_factions[faction]["ranks"], sortByRank) do
                    ranks = ranks .. translate("st_rank_" .. rank) .. ", "
                end
                ranks = string.sub(ranks, 1, -3)
                parts[#parts + 1] = ranks
            else
                parts[#parts + 1] = ""
            end
        end
        write_csv(file, unpack(parts))
        cnt = cnt + 1
    end

    file:close()

    send_log(x, "[END] weapon drop sources - %s total guns exported", cnt)
end


function debug_cmd_list.cmd.export_item_list(_, txt, x)
    send_log(x, "[START] export items list")

    -- Load buy_sell ini file for loot check
    local buy_sell_ini = ini_file("items\\trade\\gulag_job_trade_buy_sell.ltx")

    local tbl = {}
    local cnt = 0
    ini_sys:section_for_each(function(section)
        if is_multiplayer_item(section) then
            return
        end

        -- Get basic item properties
        local kind = ini_sys:r_string_ex(section, "kind") or ""

        -- Skip if no kind (not an item) or empty section
        if kind == "" then
            return
        end

        -- Create item data structure with only the requested fields
        local item = {}
        item.name = translate_with_context(ini_sys:r_string_ex(section, "inv_name"), "item name for " .. section)
        item.cost = ini_sys:r_float_ex(section, "cost") or 0
        item.kind = kind

        -- Check if can be looted by seeing if it exists in any section of buy_sell.ltx
        local can_be_looted = "N"
        buy_sell_ini:section_for_each(function(bs_section)
            if buy_sell_ini:line_exist(bs_section, section) then
                can_be_looted = "Y"
                return true -- break from the loop
            end
            return false -- continue
        end)
        item.can_be_looted = can_be_looted

        tbl[section] = item
        cnt = cnt + 1
    end)

    local p_file = "export_items_list.csv"
    local debug_file = file_for_write(p_file)

    local header = translate_headers({
        "~", "pda_encyclopedia_name", "st_ui_dbg_spawn_type", "st_upgr_cost", "st_data_export_can_be_looted_by_npc"
    })

    write_csv_header(debug_file, header)
    local sorted_keys = sort_keys(tbl)
    for _, section in ipairs(sorted_keys) do
        local v = tbl[section]
        write_csv(debug_file,
            section, v.name, v.kind, v.cost, v.can_be_looted
        )
    end
    debug_file:close()

    send_log(x, "[END] export items - %s total items exported", cnt)
end

function debug_cmd_list.cmd.export_items_common_data(_, txt, x)
    send_log(x, "[START] export items common data")

    local tbl = {}
    local cnt = 0
    ini_sys:section_for_each(function(section)
        if is_multiplayer_item(section) then return end

        local kind = ini_sys:r_string_ex(section, "kind") or ""
        if kind == "" then return end

        local item = {}
        item.class       = ini_sys:r_string_ex(section, "class") or ""
        item.kind        = kind
        item.name        = translate_with_context(ini_sys:r_string_ex(section, "inv_name"), "item name for " .. section)
        item.description = (translate_with_context(ini_sys:r_string_ex(section, "description"), "description for " .. section) or ""):sanitize()
        item.weight      = floor_with_precision(ini_sys:r_float_ex(section, "inv_weight") or 0)
        item.cost        = ini_sys:r_float_ex(section, "cost") or 0
        item.max_uses    = ini_sys:r_float_ex(section, "max_uses") or ""
        icon_candidates[section] = true

        tbl[section] = item
        cnt = cnt + 1
    end)

    local p_file = "export_items_common_data.csv"
    local f = file_for_write(p_file)
    local header = translate_headers({
        "~", "st_class", "st_ui_dbg_spawn_type", "pda_encyclopedia_name",
        "st_data_export_description", "st_prop_weight", "st_upgr_cost", "st_data_export_max_uses"
    })
    write_csv_header(f, header)
    local sorted_keys = sort_keys(tbl)
    for _, section in ipairs(sorted_keys) do
        local v = tbl[section]
        write_csv(f, section, v.class, v.kind, v.name, v.description, v.weight, v.cost, v.max_uses)
    end
    f:close()

    send_log(x, "[END] export items common data - %s items exported", cnt)
end

function debug_cmd_list.cmd.export_stash_drop_rates(_, txt, x)
    send_log(x, "[START] export stash drop rates")

    local use_item_names = true  -- set to true to output display names instead of section IDs

    -- Load config files
    local ini_tm   = treasure_manager.ini_treasure
    local ini_tier = treasure_manager.ini_tiers

    -- Parse kind/tier effects for common and rare stash types
    local kind_effects = { common = {}, rare = {} }
    local stash_sections = { common = "kind_tier_effect_common", rare = "kind_tier_effect_rare" }
    local stash_type_labels = {
        common = translate("st_data_export_stash_type_common"),
        rare   = translate("st_data_export_stash_type_rare"),
    }
    local num_tiers = 5

    for stash_type, ltx_section in pairs(stash_sections) do
        local n = ini_tm:line_count(ltx_section)
        for i = 0, n - 1 do
            local _, kind, value = ini_tm:r_line(ltx_section, i, "", "")
            if kind and value and kind ~= "" and value ~= "" then
                local str = str_explode(value, ",")
                if #str >= (2 + num_tiers * 2) then
                    local entry = {
                        chance = tonumber(str[1]),
                        tiers  = {}
                    }
                    for tier = 1, num_tiers do
                        entry.tiers[tier] = {
                            chance_multi = tonumber(str[(tier * 2) + 1])
                        }
                    end
                    kind_effects[stash_type][kind] = entry
                end
            end
        end
    end

    -- Parse possible_items: build section -> {kind, tier, allowed_ecos}
    local all_ecos = { 1, 2, 3 }
    local items = {}
    local n = ini_tm:line_count("possible_items")
    for i = 0, n - 1 do
        local _, section, value = ini_tm:r_line("possible_items", i, "", "")
        if section and section ~= "" then
            -- Compute allowed ecos by inverting the blacklist
            local blacklist_set = {}
            if value and value ~= "" then
                local bl = str_explode(value, ",")
                for _, v in ipairs(bl) do
                    local n = tonumber(v)
                    if n then blacklist_set[n] = true end
                end
            end
            local allowed = {}
            for _, e in ipairs(all_ecos) do
                if not blacklist_set[e] then allowed[#allowed + 1] = e end
            end
            local allowed_ecos = table.concat(allowed, "/")

            -- Get kind from ini_sys
            local kind = ini_sys:r_string_ex(section, "kind")
            if not kind then goto continue end

            -- Get tier from grok_items_tier.ltx; handle multi-use items
            local sec_p = section
            local uses, max_uses = 1, 1
            local sec_base, sec_uses = utils_item.get_defined_uses(section)
            if sec_base and sec_uses and ini_sys:section_exist(sec_base) then
                sec_p     = sec_base
                uses      = sec_uses
                max_uses  = ini_sys:r_float_ex(sec_base, "max_uses") or sec_uses
            end

            local tier = ini_tier:r_float_ex(sec_p, "tier")
            if not tier then goto continue end

            local lost_uses = max_uses - uses
            tier = math.ceil(tier - (lost_uses / 2))
            tier = clamp(tier, 1, 5)

            local inv_name = translate_with_context(ini_sys:r_string_ex(sec_p, "inv_name"), "item name for " .. sec_p)
            items[section] = { kind = kind, tier = tier, allowed_ecos = allowed_ecos, name = inv_name }

            ::continue::
        end
    end

    -- Open output file and write header
    local p_file = "export_stash_drop_rates.csv"
    local out = file_for_write(p_file)

    local header = translate_headers({
        "~",
        "st_data_export_stash_map",
        "st_data_export_stash_type",
        "st_data_export_stash_item",
        "st_data_export_stash_chance",
        "st_data_export_stash_ecos"
    })
    out:write(header .. "\n")

    -- Iterate maps and stash types
    local row_count = 0
    local sorted_keys = sort_keys(treasure_manager.map_tiers)
    for _, map_name in ipairs(sorted_keys) do
        local vec = treasure_manager.map_tiers[map_name]
        -- Count tier occurrences in the map's tier vector
        local tier_counts = {}
        for _, t in ipairs(vec) do
            tier_counts[t] = (tier_counts[t] or 0) + 1
        end
        local vec_size = #vec

        for stash_type, effects in pairs(kind_effects) do
            -- Compute effective chance for every item on this map+type
            local row_items = {}
            for section, item in pairs(items) do
                local kind = item.kind
                local tier = item.tier
                local kfx  = effects[kind]
                if kfx and kfx.tiers[tier] then
                    local tier_prob     = (tier_counts[tier] or 0) / vec_size
                    local spawn_check   = kfx.chance * kfx.tiers[tier].chance_multi
                    local effective_pct = tier_prob * spawn_check
                    if effective_pct > 0 then
                        row_items[#row_items + 1] = {
                            label        = use_item_names and item.name:sanitize() or section,
                            pct          = effective_pct,
                            allowed_ecos = item.allowed_ecos
                        }
                    end
                end
            end

            -- Sort descending by effective chance
            table.sort(row_items, function(a, b) return a.pct > b.pct end)

            -- Build and write the row
            local parts = { map_name, translate(map_name), stash_type_labels[stash_type] }
            for _, entry in ipairs(row_items) do
                parts[#parts + 1] = entry.label
                parts[#parts + 1] = to_percent_stash(entry.pct)
                parts[#parts + 1] = entry.allowed_ecos
            end
            write_csv(out, unpack(parts))
            row_count = row_count + 1
        end
    end

    out:close()
    send_log(x, "[END] export stash drop rates - %s map rows written", row_count)
end

function debug_cmd_list.cmd.export_toolkit_map_rates(_, txt, x)
    send_log(x, "[START] export toolkit map rates")

    -- Toolkit probability per tier (steady-state: all prerequisite kits already found)
    local toolkit_probs = {
        [1] = { itm_ammokit = 1/2,   itm_drugkit = 1/2 },
        [2] = { itm_ammokit = 1/4,   itm_drugkit = 1/4,   itm_basickit = 2/4 },
        [3] = { itm_ammokit = 2/11,  itm_drugkit = 2/11,  itm_basickit = 5/11, itm_advancedkit = 2/11 },
        [4] = { itm_advancedkit = 1 },
        [5] = { itm_expertkit   = 1 },
    }
    local toolkit_order = { "itm_basickit", "itm_advancedkit", "itm_expertkit", "itm_drugkit", "itm_ammokit" }

    -- Resolve toolkit display names for column headers
    local toolkit_names = {}
    for _, sec in ipairs(toolkit_order) do
        toolkit_names[sec] = translate_with_context(ini_sys:r_string_ex(sec, "inv_name"), "toolkit name for " .. sec)
    end

    -- Open output file
    local p_file = "export_toolkit_map_rates.csv"
    local out = file_for_write(p_file)

    -- Write header
    local header_parts = { "~", translate("st_data_export_stash_map") }
    for _, sec in ipairs(toolkit_order) do
        header_parts[#header_parts + 1] = toolkit_names[sec]
    end
    out:write(table.concat(header_parts, ",") .. "\n")

    -- Sort maps alphabetically
    local sorted_maps = {}
    for map_name in pairs(treasure_manager.tools_map_tiers) do
        sorted_maps[#sorted_maps + 1] = map_name
    end
    table.sort(sorted_maps)

    -- Compute and write one row per map
    local row_count = 0
    for _, map_name in ipairs(sorted_maps) do
        local vec = treasure_manager.tools_map_tiers[map_name]

        -- Count tier occurrences
        local tier_counts = {}
        for _, t in ipairs(vec) do
            tier_counts[t] = (tier_counts[t] or 0) + 1
        end
        local vec_size = #vec

        -- Weighted sum of per-tier toolkit probabilities
        local kit_pct = {}
        for tier, count in pairs(tier_counts) do
            local tier_prob = count / vec_size
            local probs = toolkit_probs[tier]
            if probs then
                for sec, p in pairs(probs) do
                    kit_pct[sec] = (kit_pct[sec] or 0) + tier_prob * p
                end
            end
        end

        -- Build row
        local cols = { map_name, translate(map_name) }
        for _, sec in ipairs(toolkit_order) do
            cols[#cols + 1] = to_percent_stash((kit_pct[sec] or 0)*100)
        end
        out:write(table.concat(cols, ",") .. "\n")
        row_count = row_count + 1
    end

    out:close()
    send_log(x, "[END] export toolkit map rates - %s map rows written", row_count)
end

function debug_cmd_list.cmd.export_upgrades(_, txt, x)
    send_log(x, "[START] export upgrades")

    -- ── Pass 1: collect all items with upgrades ──────────────────────────
    local all_items = {}  -- section -> { name, upgrades[] }
    local all_stats_sections = {}  -- stat_type -> { stats_section -> true }

    local blacklist = {
        ["wpn_kar98_retrotac"] = true, -- gun is missing
    }

    ini_sys:section_for_each(function(section)
        if blacklist[section] or is_multiplayer_item(section) then return end

        local class = ini_sys:r_string_ex(section, "class")
        local kind = ini_sys:r_string_ex(section, "kind")
        if kind == "" then kind = class end
        if kind and weapon_kinds[kind] and is_weapon_modification(section) then
            return
        end

        local upg_str = ini_sys:r_string_ex(section, "upgrades")
        if not upg_str or upg_str == "" then return end

        local name = ini_sys:r_string_ex(section, "inv_name")
        if name == nil then
            printf("Skipping [%s] because it has no inv_name", section)
            return
        end

        name = translate_with_context(name, "item name for " .. section)
        if not name or name == "" then return end

        local tree = utils_item.get_upgrades_tree(section)
        if not next(tree) then return end

        local type = (IsItem("outfit", section) or IsItem("helmet", section)) and "outfit"
                  or (ini_sys:r_string_ex(section, "ammo_class") and not IsItem("fake_ammo_wpn", section)) and "weapon"
                  or "any"

        -- Flatten tree into sorted list
        local upgrades = {}
        for row, v in pairs(tree) do
            for col, w in pairs(v) do
                if w.stats then
                    upgrades[#upgrades + 1] = {
                        row    = row,
                        column = math.ceil(col / 2),         -- tier column 1-3
                        cell   = (col % 2 == 0) and 2 or 1, -- position in column: 1 or 2
                        sec    = w.section,
                        stats  = w.stats,
                        prop   = w.prop,
                        desc   = w.desc,
                        uname  = w.name or "",
                    }
                    if type then
                        all_stats_sections[type] = all_stats_sections[type] or {}
                        all_stats_sections[type][w.stats] = true
                    end
                end
            end
        end
        table.sort(upgrades, function(a, b)
            if a.row ~= b.row then return a.row < b.row end
            if a.column ~= b.column then return a.column < b.column end
            return a.cell < b.cell
        end)

        all_items[section] = { name = name, upgrades = upgrades }
    end)

    -- ── Pass 2: determine max upgrade count for File 1 column width ──────
    local max_upg = 0
    for _, item in pairs(all_items) do
        if #item.upgrades > max_upg then max_upg = #item.upgrades end
    end

    -- ── File 1: items CSV ────────────────────────────────────────────────
    local f1 = file_for_write("export_upgrades_items.csv")

    local h1 = "~,Name"
    for i = 1, max_upg do
        h1 = h1 .. string.format(",Row_%d,Column_%d,Cell_%d,Property_%d,Value_%d,Name_%d,Desc_%d,Section_%d", i, i, i, i, i, i, i, i)
    end
    f1:write(h1 .. "\n")

    local sorted_sections = {}
    for sec in pairs(all_items) do sorted_sections[#sorted_sections + 1] = sec end
    table.sort(sorted_sections)

    local properties = ini_file("items\\weapons\\upgrades_properties.ltx")
    local char_ini = ini_file("item_upgrades.ltx")

    local item_count = 0
    for _, sec in ipairs(sorted_sections) do
        local item = all_items[sec]
        local parts = { sec, item.name }
        for i = 1, max_upg do
            local u = item.upgrades[i]
            if u then
                local property_name = properties:r_string_ex(u.prop[1], "name") or ""
                local property_value = char_ini:r_string_ex(u.stats, "value") or ""
                parts[#parts+1] = u.row
                parts[#parts+1] = u.column
                parts[#parts+1] = u.cell
                parts[#parts+1] = translate_with_context(property_name, "upgrade property for " .. u.sec)
                parts[#parts+1] = property_value
                parts[#parts+1] = translate_with_context(u.uname, "upgrade name for " .. u.sec)
                parts[#parts+1] = translate_with_context(u.desc, "upgrade description for " .. u.sec)
                parts[#parts+1] = u.stats
            else
                parts[#parts+1] = ""
                parts[#parts+1] = ""
                parts[#parts+1] = ""
                parts[#parts+1] = ""
                parts[#parts+1] = ""
                parts[#parts+1] = ""
                parts[#parts+1] = ""
                parts[#parts+1] = ""
            end
        end
        f1:write(table.concat(parts, ",") .. "\n")
        item_count = item_count + 1
    end
    f1:close()
    send_log(x, "export upgrades - %s items written", item_count)

    -- ── Pass 3: determine max property count for File 2 column width ─────
    local max_props = 0
    for _, sections in pairs(all_stats_sections) do
        for stats_sec in pairs(sections) do
            local n = ini_sys:line_count(stats_sec)
            if n and n > max_props then max_props = n end
        end
    end

    -- ── File 2: upgrade sections CSV ─────────────────────────────────────
    local f2 = file_for_write("export_upgrade_sections.csv")

    local h2 = "Section,Type"
    for i = 1, max_props do
        h2 = h2 .. string.format(",Key_%d,Value_%d", i, i)
    end
    f2:write(h2 .. "\n")

    -- Collect (stat_type, stats_sec) pairs and sort by type then section
    local sorted_stats = {}
    for stat_type, sections in pairs(all_stats_sections) do
        for stats_sec in pairs(sections) do
            sorted_stats[#sorted_stats + 1] = { stat_type = stat_type, stats_sec = stats_sec }
        end
    end
    table.sort(sorted_stats, function(a, b)
        if a.stat_type ~= b.stat_type then return a.stat_type < b.stat_type end
        return a.stats_sec < b.stats_sec
    end)

    local stats = {}
    local sec_count = 0
    for _, entry in ipairs(sorted_stats) do
        local stat_type = entry.stat_type
        local stats_sec = entry.stats_sec
        local n = ini_sys:line_count(stats_sec) or 0
        local props_written = 0
        local parts = {stats_sec, stat_type}

        local disable_in_second_pass = {
            ["hit_fraction_actor"] = true,
            ["silencer_light_range"] = true,
            ["misfire_start_prob"] = true,
            ["misfire_end_prob"] = true,
            ["PDM_disp_vel_factor"] = true,
            ["silencer_smoke_particles"] = true,
            ["shell_particles"] = true,
            ["scope_zoom_factor"] = true,
            ["scope_status"] = true,
            ["fire_modes"] = true,
            ["scope_alive_detector"] = true,
            ["9a91ue"] = true,
            ["zoom_cam_dispersion"] = true,
            ["cam_dispersion_frac"] = true,
            ["silencer_light_time"] = true,
            ["scopes_sect"] = true,
            ["snd_shoot1"] = true,
            ["cam_step_angle_horz"] = true,
            ["condition_shot_dec"] = true,
            ["silencer_y"] = true,
            ["fire_dispersion_base"] = true,
            ["PDM_disp_accel_factor"] = true,
            ["power_loss"] = true,
            ["cam_dispersion"] = true,
            ["silencer_light_var_range"] = true,
            ["silencer_light_color"] = true,
            ["zoom_cam_step_angle_horz"] = true,
            ["zoom_cam_dispersion_inc"] = true,
            ["snd_silncer_shot"] = true,
            ["silencer_light_var_color"] = true,
            ["bones_koeff_protection_add"] = true,
            ["silencer_status"] = true,
            ["fire_distance"] = true,
            ["crosshair_inertion"] = true,
            ["snd_silncer_shot_actor"] = true,
            ["condition_queue_shot_dec"] = true,
            ["cam_dispersion_inc"] = true,
            ["hit_impulse"] = true,
            ["scope_nightvision"] = true,
            ["bullet_speed"] = true,
            ["bleeding_restore_speed"] = true,
            ["grenade_launcher_name"] = true,
            ["grenade_launcher_y"] = true,
            ["grenade_launcher_x"] = true,
            ["PDM_disp_base"] = true,
            ["silencer_name"] = true,
            ["silencer_x"] = true,
            ["snd_shoot"] = true,
            ["scope_dynamic_zoom"] = true,
            ["grenade_launcher_status"] = true,
            ["value"] = true,
        }

        -- First pass for prioritized upgrades
        for i = 0, n - 1 do
            local _, key, val = ini_sys:r_line(stats_sec, i, "", "")
            if not key or key == "" then goto continue end
            stats[key] = true

            if key == "bones_koeff_protection_add" then
                local display_val = tostring(get_real_stat_value_display(stats_sec, 0, "outfit", "fire_wound_protection"))
                key = "fire_wound_protection"
                parts[#parts + 1] = key
                parts[#parts + 1] = sanitize_value(display_val)
                props_written = props_written + 1
                disable_in_second_pass[key] = true
            end
            ::continue::
        end

        for i = 0, n - 1 do
            local _, key, val = ini_sys:r_line(stats_sec, i, "", "")
            if key and key ~= "" and not disable_in_second_pass[key] then
                if key == "ammo_class" then
                    val = get_weapon_caliber(val)
                end

                local num_val = tonumber(val)
                local display_val = val or ""
                if num_val and utils_ui.stats_table[stat_type] then
                    display_val = tostring(get_real_stat_value_display(stats_sec, num_val, stat_type, key))
                end
                parts[#parts + 1] = key
                parts[#parts + 1] = sanitize_value(display_val)
                props_written = props_written + 1
                ::continue::
            end
        end

        for _ = props_written + 1, max_props do
            parts[#parts + 1] = ""
        end
        f2:write(table.concat(parts, ",") .. "\n")
        sec_count = sec_count + 1
    end
    f2:close()

    for stat, _ in pairs(stats) do
        printf(stat)
    end

    send_log(x, "[END] export upgrades - %s items, %s upgrade sections", item_count, sec_count)
end

function debug_cmd_list.cmd.export_item_icons(_, txt, x)
    send_log(x, "[START] export item icons")

    local blacklist = {
        ["weapon_ammo_parts"] = true, -- not an item
    }
    local tbl = {}
    local cnt = 0
    for section, _ in pairs(icon_candidates) do
        local grid_x = ini_sys:r_float_ex(section, "inv_grid_x")
        if not grid_x then goto continue end

        if blacklist[section] or is_multiplayer_item(section) then goto continue end

        local class = ini_sys:r_string_ex(section, "class")
        local kind = ini_sys:r_string_ex(section, "kind")
        if kind == "" then kind = class end
        if kind and weapon_kinds[kind] and is_weapon_modification(section) then
            goto continue
        end

        local item = {}
        local axis = utils_xml.get_item_axis(section)
        item.texture = utils_xml.get_icons_texture(section) or ""
        item.width   = axis.w
        item.height  = axis.h
        item.x       = axis.x1
        item.y       = axis.y1

        tbl[section] = item
        cnt = cnt + 1
        ::continue::
    end

    local f = file_for_write("export_item_icons.csv")
    f:write("id,texture,width,height,x,y\n")

    local sorted_keys = sort_keys(tbl)
    for _, section in ipairs(sorted_keys) do
        local v = tbl[section]
        write_csv(f, section, v.texture, v.width, v.height, v.x, v.y)
    end
    f:close()

    send_log(x, "[END] export item icons - %s sections written", cnt)
end

function debug_cmd_list.cmd.export_item_drop_locations(_, txt, x)
    send_log(x, "[START] export stash drop rates by item")

    -- Load config files
    local ini_tm   = treasure_manager.ini_treasure
    local ini_tier = treasure_manager.ini_tiers

    -- Parse kind/tier effects for common and rare stash types
    local kind_effects = { common = {}, rare = {} }
    local stash_sections = { common = "kind_tier_effect_common", rare = "kind_tier_effect_rare" }
    local stash_type_labels = {
        common = translate("st_data_export_stash_type_common"),
        rare   = translate("st_data_export_stash_type_rare"),
    }
    local num_tiers = 5

    for stash_type, ltx_section in pairs(stash_sections) do
        local n = ini_tm:line_count(ltx_section)
        for i = 0, n - 1 do
            local _, kind, value = ini_tm:r_line(ltx_section, i, "", "")
            if kind and value and kind ~= "" and value ~= "" then
                local str = str_explode(value, ",")
                if #str >= (2 + num_tiers * 2) then
                    local entry = { chance = tonumber(str[1]), tiers = {} }
                    for tier = 1, num_tiers do
                        entry.tiers[tier] = { chance_multi = tonumber(str[(tier * 2) + 1]) }
                    end
                    kind_effects[stash_type][kind] = entry
                end
            end
        end
    end

    -- Parse possible_items: build section -> {kind, tier, allowed_ecos, name}
    local all_ecos = { 1, 2, 3 }
    local items = {}
    local n = ini_tm:line_count("possible_items")
    for i = 0, n - 1 do
        local _, section, value = ini_tm:r_line("possible_items", i, "", "")
        if section and section ~= "" then
            local blacklist_set = {}
            if value and value ~= "" then
                local bl = str_explode(value, ",")
                for _, v in ipairs(bl) do
                    local e = tonumber(v)
                    if e then blacklist_set[e] = true end
                end
            end
            local allowed = {}
            for _, e in ipairs(all_ecos) do
                if not blacklist_set[e] then allowed[#allowed + 1] = e end
            end
            local allowed_ecos = table.concat(allowed, "/")

            local kind = ini_sys:r_string_ex(section, "kind")
            if not kind then goto continue end

            local sec_p = section
            local uses, max_uses = 1, 1
            local sec_base, sec_uses = utils_item.get_defined_uses(section)
            if sec_base and sec_uses and ini_sys:section_exist(sec_base) then
                sec_p    = sec_base
                uses     = sec_uses
                max_uses = ini_sys:r_float_ex(sec_base, "max_uses") or sec_uses
            end

            local tier = ini_tier:r_float_ex(sec_p, "tier")
            if not tier then goto continue end

            local lost_uses = max_uses - uses
            tier = math.ceil(tier - (lost_uses / 2))
            tier = clamp(tier, 1, 5)

            local inv_name = translate_with_context(ini_sys:r_string_ex(sec_p, "inv_name"), "item name for " .. sec_p)
            items[section] = { kind = kind, tier = tier, allowed_ecos = allowed_ecos, name = inv_name }

            ::continue::
        end
    end

    -- Build per-item data: item -> stash_type -> list of {map, pct} sorted desc
    local item_maps = {}  -- item_maps[section][stash_type] = { {map, pct}, ... }

    for map_name, vec in pairs(treasure_manager.map_tiers) do
        local tier_counts = {}
        for _, t in ipairs(vec) do
            tier_counts[t] = (tier_counts[t] or 0) + 1
        end
        local vec_size = #vec

        for stash_type, effects in pairs(kind_effects) do
            for section, item in pairs(items) do
                local kfx = effects[item.kind]
                if kfx and kfx.tiers[item.tier] then
                    local tier_prob     = (tier_counts[item.tier] or 0) / vec_size
                    local spawn_check   = kfx.chance * kfx.tiers[item.tier].chance_multi
                    local effective_pct = tier_prob * spawn_check
                    if effective_pct > 0 then
                        if not item_maps[section] then item_maps[section] = {} end
                        if not item_maps[section][stash_type] then item_maps[section][stash_type] = {} end
                        local t = item_maps[section][stash_type]
                        t[#t + 1] = { map = map_name, pct = effective_pct }
                    end
                end
            end
        end
    end

    -- Sort each item's map list descending by chance
    for section, by_type in pairs(item_maps) do
        for _, map_list in pairs(by_type) do
            table.sort(map_list, function(a, b) return a.pct > b.pct end)
        end
    end

    -- Open output file and write header
    local p_file = "export_item_drop_locations.csv"
    local out = file_for_write(p_file)

    local header = translate_headers({
        "~",
        "pda_encyclopedia_name",
        "st_data_export_stash_type",
        "st_data_export_stash_map",
        "st_data_export_stash_chance",
        "st_data_export_stash_ecos"
    })
    write_csv_header(out, header)

    -- Write rows: two rows per item (common, rare), maps sorted desc by chance
    local row_count = 0
    for section, item in spairs(items) do
        local label = section
        for _, stash_type in ipairs({ "common", "rare" }) do
            local map_list = item_maps[section] and item_maps[section][stash_type]
            if map_list and #map_list > 0 then
                local parts = { label, item.name, stash_type_labels[stash_type] }
                for _, entry in ipairs(map_list) do
                    parts[#parts + 1] = translate(entry.map)
                    parts[#parts + 1] = to_percent_stash(entry.pct)
                    parts[#parts + 1] = item.allowed_ecos
                end
                write_csv_table(out, parts, true)
                row_count = row_count + 1
            end
        end
    end

    out:close()
    send_log(x, "[END] export stash drop rates by item - %s rows written", row_count)
end

function debug_cmd_list.cmd.export_npc_armor_profiles(_, txt, x)
    send_log(x, "[START] export NPC armor profiles")

    local ini_bp = grok_bo.ini_bones
    local ini_capture = grok_bo.ini_capture
    local ini_death = itms_manager.ini_death

    local function read_bonearmor(damage_sect, bone)
        if not damage_sect or damage_sect == "" then return 0 end
        local raw = ini_sys:r_string_ex(damage_sect, bone)
        if not raw then return 0 end
        local vals = str_explode(raw, ",")
        return tonumber(vals[2]) or 0
    end

    local function strip_model_path(path)
        if not path then return nil end
        -- normalize to forward slashes
        local p = path:gsub("\\", "/")
        -- get filename (part after last slash)
        local fname = p:match("([^/]+)$") or p
        -- remove last extension (e.g. ".ltx")
        local base = fname:gsub("%.[^%.]+$", "")
        return base
    end

    local tbl = {}
    local cnt = 0

    ini_capture:section_for_each(function(section)
        local npc_armor_path = ini_capture:r_string(section,"model_path")
        local ini_npc_armor = ini_file(npc_armor_path)
        if not ini_npc_armor then return end

        printf("Processing NPC armor section [%s] with model %s", section, npc_armor_path)
        local npc_armor_section = ini_npc_armor:r_string_ex('bone_protection','bones_protection_sect')
        if not npc_armor_section or npc_armor_section == "" then
            printf("Skipping [%s] because it has no bone_protection section", section)
            return
        end

        local bone_profile  = ini_bp:r_string_ex(npc_armor_section, "bone_profile") or ""
        local head_profile  = ini_bp:r_string_ex(npc_armor_section, "head_profile") or ""

        local hit_fraction  = ini_bp:r_float_ex(npc_armor_section, "hit_fraction_npc") or 0
        local ap_scale      = ini_bp:r_float_ex(npc_armor_section, "ap_scale") or 0

        local body_bonearmor = read_bonearmor(bone_profile, "bip01_spine")
        local head_bonearmor = read_bonearmor(head_profile, "bip01_head")

        local visual = strip_model_path(section)
        local real_armor = ini_death:r_string_ex("outfit_by_visual", visual) or ""

        if real_armor == "" then
            visual = strip_model_path(npc_armor_path)
            real_armor = ini_death:r_string_ex("outfit_by_visual", visual) or ""
        end


        tbl[section] = {
            item = real_armor,
            hit_fraction  = hit_fraction,
            ap_scale      = ap_scale,
            body_bonearmor = body_bonearmor,
            head_bonearmor = head_bonearmor,
        }
        cnt = cnt + 1
    end)

    local p_file = "export_npc_armor_profiles.csv"
    local f = file_for_write(p_file)
    local header = translate_headers({
        "~", "st_data_export_visual_item_id",
        "st_data_export_hit_fraction", "st_data_export_ap_scale",
        "st_data_export_body_bonearmor", "st_data_export_head_bonearmor",
    })
    write_csv_header(f, header)

    local sorted_keys = sort_keys(tbl)
    for _, section in ipairs(sorted_keys) do
        local v = tbl[section]
        write_csv(f, section, v.item, v.hit_fraction, v.ap_scale, v.body_bonearmor,
                v.head_bonearmor)
    end
    f:close()

    send_log(x, "[END] export NPC armor profiles - %s profiles written", cnt)
end

function debug_cmd_list.cmd.export_weapon_addons(_, txt, x)
    send_log(x, "[START] export addons")

    local seen_scopes    = {}
    local seen_silencers = {}
    local seen_gls       = {}

    ini_sys:section_for_each(function(section)
        if is_multiplayer_item(section) then return end

        local kind = ini_sys:r_string_ex(section, "kind")
        local class = ini_sys:r_string_ex(section, "class")
        if kind == "" then kind = class end
        if not weapon_kinds[kind] or is_weapon_modification(section) then return end

        local scopes_raw = ini_sys:r_string_ex(section, "scopes") or ""
        if scopes_raw ~= "" then
            for _, s in ipairs(str_explode(scopes_raw, ",")) do
                local id = s:trim()
                if id ~= "" and not is_multiplayer_item(id) then seen_scopes[id] = true end
            end
        end
        local scope_name = ini_sys:r_string_ex(section, "scope_name")
        if scope_name and scope_name ~= "" and not is_multiplayer_item(scope_name) then seen_scopes[scope_name] = true end

        local sil = ini_sys:r_string_ex(section, "silencer_name")
        if sil and sil ~= "" and not is_multiplayer_item(sil) then seen_silencers[sil] = true end

        local gl = ini_sys:r_string_ex(section, "grenade_launcher_name")
        if gl and gl ~= "" and not is_multiplayer_item(gl) then seen_gls[gl] = true end
    end)

    local function write_addon_file(filename, seen, include_zoom)
        local f = file_for_write(filename)
        local header_keys = { "~", "pda_encyclopedia_name", "st_data_export_description", "st_prop_weight", "st_upgr_cost" }
        if include_zoom then
            table.insert(header_keys, "st_data_export_zoom_factor")
            table.insert(header_keys, "st_data_export_magnifications")
        end
        write_csv_header(f, translate_headers(header_keys))

        local cnt = 0
        local sorted_keys = sort_keys(seen)
        for _, id in ipairs(sorted_keys) do
            local name = translate_with_context(ini_sys:r_string_ex(id, "inv_name"), "item name for " .. id)
            local desc = (translate_with_context(ini_sys:r_string_ex(id, "description"), "description for " .. id) or ""):sanitize()
            local weight = floor_with_precision(ini_sys:r_float_ex(id, "inv_weight") or 0)
            local cost = ini_sys:r_float_ex(id, "cost") or 0
            if include_zoom then
                local zoom = ini_sys:r_float_ex(id, "scope_zoom_factor") or ""
                local magnifications = ini_sys:r_string_ex(id, "magnifications") or ""
                write_csv(f, id, name, desc, weight, cost, zoom, magnifications)
            else
                write_csv(f, id, name, desc, weight, cost)
            end
            icon_candidates[id] = true
            cnt = cnt + 1
        end
        f:close()
        return cnt
    end

    local scope_cnt = write_addon_file("export_scopes.csv", seen_scopes, true)
    local silen_cnt = write_addon_file("export_silencers.csv", seen_silencers, false)
    local gl_cnt    = write_addon_file("export_grenade_launchers.csv", seen_gls, false)

    send_log(x, "[END] export addons - %s scopes, %s silencers, %s grenade launchers", scope_cnt, silen_cnt, gl_cnt)
end

function debug_cmd_list.cmd.export_weapon_addon_map(_, txt, x)
    send_log(x, "[START] export weapon addon map")

    local f = file_for_write("export_weapon_addon_map.csv")
    local cnt = 0
    local reverse = {}  -- addon_id -> list of weapon sections

    local sections_queue = {}
    ini_sys:section_for_each(function(section)
        local kind = ini_sys:r_string_ex(section, "kind")
        local class = ini_sys:r_string_ex(section, "class")
        if kind == "" then kind = class end
        if weapon_kinds[kind] and not is_weapon_modification(section) and not is_multiplayer_item(section) then
            table.insert(sections_queue, section)
        end
    end)
    table.sort(sections_queue)

    for _, section in ipairs(sections_queue) do
        local row = { section }
        local seen = {}

        local function add_addon(id)
            if not seen[id] then
                seen[id] = true
                table.insert(row, id)
                if not reverse[id] then reverse[id] = {} end
                table.insert(reverse[id], section)
            end
        end

        local scopes_raw = ini_sys:r_string_ex(section, "scopes") or ""
        if scopes_raw ~= "" then
            for _, s in ipairs(str_explode(scopes_raw, ",")) do
                local id = s:trim()
                if id ~= "" then add_addon(id) end
            end
        end
        local scope_name = ini_sys:r_string_ex(section, "scope_name")
        if scope_name and scope_name ~= "" then add_addon(scope_name) end

        local sil = ini_sys:r_string_ex(section, "silencer_name")
        if sil and sil ~= "" then add_addon(sil) end

        local gl = ini_sys:r_string_ex(section, "grenade_launcher_name")
        local gl_status = ini_sys:r_float_ex(section, "grenade_launcher_status")
        if gl and gl ~= "" and gl_status == 2 then add_addon(gl) end

        if #row > 1 then
            write_csv(f, unpack(row))
            cnt = cnt + 1
        end
    end
    f:close()

    -- Reverse map: addon_id, weapon_1, weapon_2, ...
    local fr = file_for_write("export_addon_weapon_map.csv")
    local sorted_keys = sort_keys(reverse)
    for _, id in ipairs(sorted_keys) do
        local row = {id}
        for _, weapon in ipairs(reverse[id]) do
            table.insert(row, weapon)
        end
        write_csv(fr, unpack(row))
    end
    fr:close()

    send_log(x, "[END] export weapon addon map - %s weapons, %s addons written", cnt, #sorted_keys)
end

-- Set of character IDs (from npc_profile*.xml) that have no matching <class> in character_desc files.
-- Populated by build_character_blacklist(); used to skip NPCs with no concrete character profile.
local character_blacklist = {}

--run_string universal_anomaly_data_export.build_character_blacklist()
function build_character_blacklist()
    local cfg_path = getFS():update_path("$game_config$", "")
    local gameplay_path = cfg_path .. "gameplay\\"

    -- Collect all <class> values from character_desc files,
    -- recursively resolving #include directives.
    local known_classes = {}
    local visited = {}
    local classes_count = 0

    local function read_classes(filepath)
        if visited[filepath] then return end
        visited[filepath] = true
        local f = io.open(filepath, "r")
        if not f then
            printf("build_character_blacklist - cannot open: %s", filepath)
            return
        end
        local lines = {}
        for line in f:lines() do lines[#lines + 1] = line end
        f:close()
        local content = table.concat(lines, "\n")
        for cls in content:gmatch('<class>([^<]+)</class>') do
            known_classes[cls:trim()] = true
            classes_count = classes_count + 1
        end
        for inc in content:gmatch('#include%s+"([^"]+)"') do
            read_classes(cfg_path .. inc:gsub("/", "\\"))
        end
    end

    local specific_characters_files_str = ini_sys:r_string_ex("profiles", "specific_characters_files")
    local specific_characters_files = str_explode(specific_characters_files_str or "", ",")
    for _, name in ipairs(specific_characters_files) do
        read_classes(gameplay_path .. name:trim() .. ".xml")
    end
    printf("build_character_blacklist - loaded %s known classes from character_desc files", classes_count)

    -- Read all profile files and blacklist any <character> whose id has no matching <class> in desc files.
    local size = 0
    character_blacklist = {}
    local profiles_str = ini_sys:r_string_ex("profiles", "files")
    local profiles = str_explode(profiles_str or "", ",")
    for _, name in ipairs(profiles) do
        local filepath = gameplay_path .. name:trim() .. ".xml"
        local f = io.open(filepath, "r")
        if f then
            local lines = {}
            for line in f:lines() do lines[#lines + 1] = line end
            f:close()
            local content = table.concat(lines, "\n")
            for id in content:gmatch('<character%s+id="([^"]+)"') do
                if not known_classes[id] then
                    size = size + 1
                    character_blacklist[id] = true
                    printf("build_character_blacklist - blacklisted: %s (no matching class in desc)", id)
                end
            end
        else
            printf("build_character_blacklist - cannot open profile: %s", filepath)
        end
    end
    printf("build_character_blacklist - done, %s characters blacklisted", size)
end

